    "backgroundColor": "#ffffff",
    "borderStyle": "white",
    "list": [
      { "pagePath": "pages/schedule/index", "text": "日程" },
      { "pagePath": "pages/collab/index", "text": "协作" },
      { "pagePath": "pages/tasks/index", "text": "任务" },
      { "pagePath": "pages/mine/index", "text": "我的" }
    ]
  },
  "sitemapLocation": "sitemap.json",
  "usingComponents": {
    "skeleton": "components/skeleton/index",
    "privacy-agreement": "components/privacy-agreement/index",
    "compact-header": "components/compact-header/index",
    "category-picker": "components/category-picker/index"
