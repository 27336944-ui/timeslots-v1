.tab-bar {
  display: flex;
  height: 100rpx;
  background: #fff;
  border-top: 1rpx solid #E5E7EB;
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: content-box;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.tab-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #9CA3AF;
  line-height: 1;
}

.tab-active .tab-text {
  color: #10B981;
  font-weight: 600;
}

.tab-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #10B981;
}
