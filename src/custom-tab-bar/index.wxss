.tab-bar {
  display: flex;
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 88rpx;
  background: var(--ts-primary-bg);
  border-top: 1rpx solid var(--ts-border);
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: content-box;
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  gap: 4rpx;
}

.tab-icon {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: var(--ts-font-caption);
  font-weight: var(--weight-bold);
  border-radius: var(--ts-radius-sm);
  background: var(--ts-bg-disabled);
  color: var(--ts-text-tertiary);
  transition: all 0.2s ease;
}

.tab-active .tab-icon {
  background: var(--ts-primary);
  color: var(--ts-bg-card);
}

.tab-text {
  font-size: var(--ts-font-callout);
  font-weight: var(--weight-medium);
  color: var(--ts-text-tertiary);
  line-height: 1;
}

.tab-active .tab-text {
  color: var(--ts-primary);
  font-weight: var(--weight-semibold);
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: var(--ts-primary);
}
