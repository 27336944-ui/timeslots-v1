<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="index"
    class="tab-item {{selected === index ? 'tab-active' : ''}}"
    data-index="{{index}}"
    bindtap="onTabTap"
    aria-role="tab"
    aria-label="{{item.text}}"
  >
    <text class="tab-icon">{{item.icon}}</text>
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>
