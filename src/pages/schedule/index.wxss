.page {
  height: 100vh;
  background: #f5f5f5;
}

.date-header {
  position: sticky;
  top: 0;
  z-index: 10;
  background: #fff;
  padding: 16rpx 32rpx;
  border-bottom: 1rpx solid #eee;
}

.date-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 12rpx;
}

.nav-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333;
}

.date-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  min-width: 200rpx;
  text-align: center;
}

.view-tabs {
  display: flex;
  justify-content: center;
  gap: 8rpx;
}

.view-tab {
  padding: 6rpx 24rpx;
  font-size: 26rpx;
  color: #999;
  border-radius: 20rpx;
}

.view-tab.active {
  background: #4A6CF7;
  color: #fff;
}

.timeline {
  padding: 0 32rpx;
}

.hour-row {
  display: flex;
  align-items: stretch;
  min-height: 80rpx;
}

.hour-marker {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100rpx;
  flex-shrink: 0;
  padding-top: 16rpx;
}

.hour-label {
  font-size: 24rpx;
  color: #bbb;
  font-weight: 500;
}

.hour-label.has-blocks {
  color: #4A6CF7;
  font-weight: 700;
}

.hour-line {
  width: 2rpx;
  flex: 1;
  background: #e8e8e8;
  margin-top: 8rpx;
}

.hour-body {
  flex: 1;
  padding: 12rpx 0 12rpx 24rpx;
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.hour-body.expanded {
  max-height: 1000rpx;
}

.block-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.block-card.tag-work {
  border-left: 6rpx solid #4A6CF7;
}

.block-card.tag-life {
  border-left: 6rpx solid #52c41a;
}

.block-card.tag-private {
  border-left: 6rpx solid #faad14;
}

.block-left {
  flex: 1;
  min-width: 0;
}

.block-right {
  flex-shrink: 0;
  margin-left: 12rpx;
  padding-top: 4rpx;
}

.block-time {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.block-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.block-meta {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.priority-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.priority-dot.priority-high {
  background: #e74c3c;
}

.priority-dot.priority-low {
  background: #bbb;
}

.empty-hint {
  font-size: 24rpx;
  color: #ccc;
}

.loading-hint,
.error-hint {
  text-align: center;
  padding: 48rpx;
  font-size: 28rpx;
  color: #999;
}

.error-hint {
  color: #e74c3c;
}

.fab {
  position: fixed;
  right: 32rpx;
  bottom: 100rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #4A6CF7;
  color: #fff;
  font-size: 52rpx;
  font-weight: 300;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(74, 108, 247, 0.4);
  z-index: 100;
}

.fab:active {
  opacity: 0.8;
}
