.page {
  height: 100vh;
  background: var(--ts-bg-page);
}

.date-header {
  position: sticky;
  top: 0;
  z-index: 10;
  background: #fff;
  padding: 14px 48rpx 10px;
  border-bottom: 1rpx solid #eee;
}

.date-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 12rpx;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx 0;
  background: #fff;
}

.top-bar-title {
  font-size: var(--ts-font-large-title);
  font-weight: var(--weight-bold);
  letter-spacing: var(--ts-ls-large-title);
  color: #333;
}

.top-bar-actions {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.top-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.top-btn-plus {
  background: var(--ts-primary);
  color: #fff;
  font-weight: 300;
  box-shadow: 0 2rpx 8rpx rgba(16, 185, 129, 0.3);
}

.top-btn-plus:active {
  opacity: 0.85;
  transform: scale(0.92);
}

.top-btn-search {
  background: #f0f0f0;
  color: #666;
  font-size: 28rpx;
}

.top-btn-search:active {
  background: #e0e0e0;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 32rpx;
  background: #fff;
}

.search-input {
  flex: 1;
  height: 64rpx;
  border-radius: 32rpx;
  background: var(--ts-bg-disabled);
  padding: 0 24rpx;
  font-size: var(--ts-font-body);
  color: #333;
}

.search-cancel {
  font-size: 26rpx;
  color: var(--ts-primary);
  padding: 8rpx;
}

.nav-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--ts-bg-disabled);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--ts-text-primary);
}

.date-text {
  font-size: var(--ts-font-title1);
  font-weight: var(--weight-semibold);
  letter-spacing: var(--ts-ls-card-title);
  color: #333;
  min-width: 200rpx;
  text-align: center;
}

.view-tabs {
  display: flex;
  justify-content: center;
  gap: 8rpx;
}

.view-tab {
  padding: 6rpx 24rpx;
  font-size: var(--ts-font-callout);
  font-weight: var(--weight-medium);
  letter-spacing: var(--ts-ls-tab);
  color: #999;
  border-radius: 20rpx;
}

.view-tab.active {
  background: var(--ts-primary, #10B981);
  color: #fff;
}

.week-bar {
  display: flex;
  justify-content: space-around;
  padding: 8rpx 0 4rpx;
}

.week-day {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 4rpx;
  border-radius: 16rpx;
  min-width: 64rpx;
}

.week-day.selected {
  background: var(--ts-primary);
}

.week-day.today .week-day-num {
  color: var(--ts-primary);
  font-weight: 700;
}

.week-day.selected .week-day-num,
.week-day.selected .week-day-label {
  color: #fff;
}

.week-day.selected.today .week-day-num {
  color: #fff;
}

.week-day-label {
  font-size: 22rpx;
  color: #999;
}

.week-day-num {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-top: 2rpx;
}

.timeline {
  padding: 0 40rpx;
}

.hour-row {
  display: flex;
  align-items: stretch;
  min-height: 80rpx;
}

.hour-marker {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 96rpx;
  flex-shrink: 0;
  padding-top: 16rpx;
}

.hour-label {
  font-size: var(--ts-font-caption);
  font-weight: var(--weight-medium);
  letter-spacing: var(--ts-ls-time);
  color: #bbb;
}

.hour-label.has-blocks {
  color: var(--ts-category-work);
  font-weight: var(--weight-bold);
}

.hour-line {
  width: 1rpx;
  flex: 1;
  background: var(--ts-border);
  margin-top: 8rpx;
}

.hour-body {
  flex: 1;
  padding: 12rpx 0 12rpx 28rpx;
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.hour-body.expanded {
  max-height: 1000rpx;
}

.block-card {
  background: #fff;
  border-radius: var(--ts-card-radius);
  padding: 24rpx;
  margin-bottom: var(--ts-card-gap);
  box-shadow: var(--ts-card-shadow);
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  transition: transform 0.2s ease, opacity 0.2s ease, box-shadow 0.2s ease;
  animation: block-card-enter 0.3s ease;
}

@keyframes block-card-enter {
  from { opacity: 0; transform: translateY(-10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.block-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.08);
}

.block-card.tag-work {
  border-left: 6rpx solid var(--ts-category-work);
}

.block-card.tag-life {
  border-left: 6rpx solid var(--ts-category-life);
}

.block-card.tag-private {
  border-left: 6rpx solid var(--ts-category-private);
}

.block-left {
  flex: 1;
  min-width: 0;
}

.block-right {
  flex-shrink: 0;
  margin-left: 12rpx;
  padding-top: 4rpx;
}

.block-time {
  font-size: var(--ts-font-tiny);
  color: #999;
  margin-bottom: 4rpx;
}

.block-title {
  font-size: var(--ts-font-title1);
  font-weight: var(--weight-medium);
  letter-spacing: var(--ts-ls-card-title);
  color: #333;
}

.block-meta {
  font-size: var(--ts-font-tiny);
  color: #bbb;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.priority-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.priority-dot.priority-high {
  background: var(--ts-priority-high);
}

.priority-dot.priority-low {
  background: var(--ts-priority-low);
}

.empty-hint {
  font-size: var(--ts-font-caption);
  color: #ccc;
}

.loading-hint,
.error-hint {
  text-align: center;
  padding: 48rpx;
  font-size: var(--ts-font-body);
  color: #999;
}

.error-hint {
  color: #e74c3c;
}

.expand-all-btn {
  text-align: center;
  padding: 16rpx;
  font-size: 26rpx;
  color: var(--ts-primary);
  background: var(--ts-primary-bg);
  margin: 8rpx 0 16rpx;
  border-radius: var(--ts-radius-md);
}

.skeleton-wrap {
  padding: 32rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--ts-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  position: relative;
}

.empty-icon::before {
  content: '';
  width: 56rpx;
  height: 56rpx;
  border: 6rpx solid var(--ts-primary);
  border-radius: 8rpx;
  background: #fff;
}

.empty-icon::after {
  content: '';
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  width: 20rpx;
  height: 20rpx;
  border: 4rpx solid var(--ts-primary);
  border-radius: 50%;
  background: #fff;
}

.empty-text {
  font-size: var(--ts-font-title1);
  font-weight: var(--weight-medium);
  color: var(--ts-text-tertiary);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: var(--ts-font-callout);
  color: var(--ts-text-placeholder);
}

/* Overview card */
.overview-card {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin: 16rpx 40rpx 8rpx;
  padding: 20rpx 28rpx;
  background: #fff;
  border-radius: var(--ts-card-radius);
  box-shadow: var(--ts-card-shadow);
  flex-wrap: wrap;
}

.overview-stat {
  font-size: var(--ts-font-callout);
  font-weight: var(--weight-medium);
  color: var(--ts-text-primary);
}

.overview-sep {
  font-size: var(--ts-font-callout);
  color: var(--ts-text-placeholder);
  margin: 0 4rpx;
}

.overview-overdue {
  color: #e74c3c;
}

/* Cross-day badge */
.cross-day-badge {
  display: inline-block;
  font-size: 18rpx;
  color: #fff;
  background: var(--ts-primary, #10B981);
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  margin-left: 8rpx;
  vertical-align: middle;
}

/* Month view */
.month-view {
  padding: 0 32rpx;
}

.month-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 16rpx 0 12rpx;
}

.month-title {
  font-size: var(--ts-font-title1);
  font-weight: var(--weight-semibold);
  color: var(--ts-text-primary);
  min-width: 200rpx;
  text-align: center;
}

.month-weekdays {
  display: flex;
  justify-content: space-around;
  padding: 8rpx 0;
}

.month-weekday {
  width: 80rpx;
  text-align: center;
  font-size: var(--ts-font-callout);
  font-weight: var(--weight-medium);
  color: var(--ts-text-tertiary);
}

.month-grid {
  display: flex;
  flex-wrap: wrap;
}

.month-day {
  width: calc(100% / 7);
  height: 88rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: 12rpx;
}

.month-day:active {
  background: var(--ts-bg-disabled);
}

.month-day.other .month-day-num {
  color: var(--ts-text-placeholder);
}

.month-day.today .month-day-num {
  color: var(--ts-primary, #10B981);
  font-weight: var(--weight-bold);
}

.month-day-num {
  font-size: var(--ts-font-callout);
  color: var(--ts-text-primary);
  line-height: 1.4;
}

.month-day-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--ts-primary, #10B981);
  position: absolute;
  bottom: 8rpx;
}
