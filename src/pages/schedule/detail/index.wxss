.page {
  min-height: 100vh;
  background: var(--ts-bg-page);
  padding: 28rpx;
}

.form-group {
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: var(--ts-card-padding);
  margin-bottom: var(--ts-card-gap);
}

.form-item {
  margin-bottom: 28rpx;
  position: relative;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: var(--ts-font-caption);
  font-weight: var(--weight-semibold);
  letter-spacing: var(--ts-ls-form-label);
  text-transform: uppercase;
  color: #999;
  margin-bottom: 10rpx;
}

.form-input {
  width: 100%;
  height: 72rpx;
  border: 1rpx solid var(--ts-border);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: var(--ts-font-body);
  color: #333;
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 72rpx;
  border: 1rpx solid var(--ts-border);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: var(--ts-font-body);
  color: #333;
}

.form-picker-text {
  color: #333;
}

.form-picker-hint {
  color: #bbb;
}

.form-picker-arrow {
  font-size: var(--ts-font-callout);
  color: #ccc;
}

.form-status {
  display: flex;
  gap: var(--ts-space-sm);
}

.status-btn {
  flex: 1;
  height: 64rpx;
  border-radius: var(--ts-radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--ts-font-callout);
  border: 1rpx solid var(--ts-border);
  color: #999;
  background: var(--ts-bg-card);
}

.status-btn.active-todo {
  border-color: var(--ts-status-todo);
  color: var(--ts-status-todo);
  background: var(--ts-status-todo-bg);
}

.status-btn.active-done {
  border-color: var(--ts-status-done);
  color: var(--ts-status-done);
  background: var(--ts-status-done-bg);
}

.save-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 20rpx;
  background: var(--ts-primary);
  color: #fff;
  font-size: var(--ts-font-title1);
  font-weight: var(--weight-semibold);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--ts-card-gap);
  border: none;
}

.save-btn:active {
  opacity: 0.8;
}

.delete-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 20rpx;
  background: var(--ts-bg-card);
  color: var(--ts-danger);
  font-size: var(--ts-font-body);
  font-weight: var(--weight-medium);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid var(--ts-danger);
}

.delete-btn:active {
  background: #fff0f0;
}

.approve-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 20rpx;
  background: #faad14;
  color: #fff;
  font-size: var(--ts-font-title1);
  font-weight: var(--weight-semibold);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-top: var(--ts-space-sm);
}

.approve-btn:active {
  opacity: 0.8;
}

/* Progressive form */
.form-row {
  display: flex;
  gap: var(--ts-space-md);
  margin-bottom: 28rpx;
}

.form-item-half {
  flex: 1;
  margin-bottom: 0;
}

.form-time-group {
  display: flex;
  align-items: center;
  height: 72rpx;
  border: 1rpx solid var(--ts-border);
  border-radius: 16rpx;
  padding: 0 12rpx;
}

.form-time-group picker {
  flex: 1;
  text-align: center;
  font-size: var(--ts-font-body);
}

.form-time-sep {
  color: #ccc;
  font-size: 24rpx;
  margin: 0 4rpx;
}

.more-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0;
  font-size: var(--ts-font-body);
  color: var(--ts-primary);
  border-top: 1rpx solid var(--ts-border-light);
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

.more-toggle:active {
  opacity: 0.7;
}

.more-toggle-arrow {
  font-size: var(--ts-font-title1);
  transition: transform 0.2s ease;
}

.more-toggle-arrow-up {
  transform: rotate(90deg);
}

/* View mode styles */
.view-hero {
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: var(--ts-card-padding);
  margin-bottom: var(--ts-card-gap);
  box-shadow: var(--ts-card-shadow);
}

.view-title {
  font-size: 40rpx;
  font-weight: var(--weight-bold);
  letter-spacing: var(--ts-ls-large-title);
  color: var(--ts-text-primary);
  margin-bottom: 12rpx;
}

.view-time {
  font-size: var(--ts-font-title1);
  color: var(--ts-text-secondary);
  margin-bottom: var(--ts-space-sm);
}

.view-section {
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: var(--ts-card-padding);
  margin-bottom: var(--ts-card-gap);
  box-shadow: var(--ts-card-shadow);
}

.view-section-secondary {
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: var(--ts-card-padding);
  margin-bottom: var(--ts-card-gap);
  box-shadow: var(--ts-card-shadow);
}

.view-section-secondary .view-row {
  margin-bottom: 12rpx;
}

.view-section-secondary .view-label {
  opacity: 0.6;
}

.view-section-secondary .view-value {
  color: var(--ts-text-tertiary);
  font-size: var(--ts-font-body);
}

.view-row-created {
  margin-top: 8rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--ts-border-light);
}

.view-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: var(--ts-space-sm);
}

.view-row:last-child {
  margin-bottom: 0;
}

.view-label {
  width: 96rpx;
  font-size: var(--ts-font-caption);
  font-weight: var(--weight-semibold);
  letter-spacing: var(--ts-ls-form-label);
  text-transform: uppercase;
  color: var(--ts-text-tertiary);
  flex-shrink: 0;
  padding-top: 2rpx;
}

.view-value {
  font-size: var(--ts-font-body);
  color: var(--ts-text-secondary);
  line-height: 1.5;
  flex: 1;
}

.view-status {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: var(--ts-radius-full);
  font-size: 24rpx;
  font-weight: 500;
}

.view-status-todo {
  background: var(--ts-status-todo-bg);
  color: var(--ts-status-todo);
}

.view-status-done {
  background: var(--ts-status-done-bg);
  color: var(--ts-status-done);
}

.edit-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 20rpx;
  background: var(--ts-primary);
  color: #fff;
  font-size: var(--ts-font-title1);
  font-weight: var(--weight-semibold);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--ts-card-gap);
  border: none;
}

.edit-btn:active {
  opacity: 0.8;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  border: 1rpx solid var(--ts-border);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  font-size: var(--ts-font-body);
  color: #333;
  box-sizing: border-box;
}

.form-btn-group {
  display: flex;
  gap: 12rpx;
}

.form-btn-group-wrap {
  flex-wrap: wrap;
}

.form-btn {
  padding: 12rpx 28rpx;
  border-radius: var(--ts-radius-md);
  font-size: var(--ts-font-callout);
  border: 1rpx solid var(--ts-border);
  color: #999;
  background: var(--ts-bg-card);
  text-align: center;
}

.form-btn-sm {
  padding: 8rpx 20rpx;
  font-size: var(--ts-font-tiny);
}

.form-btn.active-work {
  border-color: var(--ts-category-work);
  color: var(--ts-category-work);
  background: var(--ts-category-work-bg);
}

.form-btn.active-life {
  border-color: var(--ts-category-life);
  color: var(--ts-category-life);
  background: var(--ts-category-life-bg);
}

.form-btn.active-private {
  border-color: var(--ts-category-private);
  color: var(--ts-category-private);
  background: var(--ts-category-private-bg);
}

.form-btn.active-public {
  border-color: var(--ts-primary);
  color: var(--ts-primary);
  background: var(--ts-primary-bg);
}

.form-btn.active-circle {
  border-color: var(--ts-primary);
  color: var(--ts-primary);
  background: var(--ts-primary-bg);
}

.form-btn.active-high {
  border-color: var(--ts-priority-high);
  color: var(--ts-priority-high);
  background: var(--ts-priority-high-bg);
}

.form-btn.active-medium {
  border-color: var(--ts-priority-medium);
  color: var(--ts-priority-medium);
  background: var(--ts-priority-medium-bg);
}

.form-btn.active-low {
  border-color: var(--ts-priority-low);
  color: var(--ts-priority-low);
  background: var(--ts-priority-low-bg);
}

.form-btn.active-none,
.form-btn.active-daily,
.form-btn.active-weekly,
.form-btn.active-monthly,
.form-btn.active-yearly {
  border-color: var(--ts-primary);
  color: var(--ts-primary);
  background: var(--ts-primary-bg);
}

/* Task picker modal */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.4);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 60vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--ts-border-light);
}

.modal-title {
  font-size: var(--ts-font-title1);
  font-weight: var(--weight-semibold);
  color: #333;
}

.modal-close {
  font-size: var(--ts-font-body);
  color: #999;
  padding: 8rpx;
}

.modal-list {
  padding: 16rpx 0;
  max-height: 50vh;
}

.modal-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--ts-border-light);
}

.modal-item:active {
  background: var(--ts-bg-disabled);
}

.modal-item-title {
  font-size: var(--ts-font-body);
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.modal-item-status {
  font-size: 22rpx;
  color: #999;
  padding: 4rpx 12rpx;
  background: #f0f4ff;
  border-radius: 8rpx;
}

.modal-empty {
  text-align: center;
  padding: 48rpx;
  font-size: 28rpx;
  color: #999;
}

.form-clear-btn {
  font-size: 28rpx;
  color: #e74c3c;
  padding: 8rpx;
}

.form-item-disabled {
  opacity: 0.4;
}

.view-task-link {
  color: var(--ts-primary);
  text-decoration: underline;
}

/* Approval BottomSheet */
.approval-sheet-body {
  padding: 16rpx 32rpx 48rpx;
}

.approval-sheet-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--ts-text-primary);
  text-align: center;
  margin-bottom: 32rpx;
}

.approval-sheet-section {
  margin-bottom: 20rpx;
}

.approval-sheet-label {
  font-size: var(--ts-font-caption);
  font-weight: var(--weight-semibold);
  letter-spacing: var(--ts-ls-form-label);
  text-transform: uppercase;
  color: var(--ts-text-secondary);
  margin-bottom: 12rpx;
}

.approval-sheet-row {
  display: flex;
  gap: 16rpx;
}

.approval-sheet-input {
  flex: 1;
  height: 72rpx;
  border: 1rpx solid var(--ts-border);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
  box-sizing: border-box;
}

.approval-sheet-add-btn {
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: var(--ts-radius-md);
  background: var(--ts-primary);
  color: #fff;
  font-size: var(--ts-font-callout);
  font-weight: var(--weight-medium);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.approval-sheet-add-btn:active {
  opacity: 0.8;
}

.approval-sheet-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.approval-sheet-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background: var(--ts-primary-bg);
  font-size: 24rpx;
  color: var(--ts-primary);
}

.approval-sheet-tag-close {
  font-size: 20rpx;
  color: var(--ts-text-tertiary);
  padding: 2rpx;
}

.approval-sheet-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 8rpx;
}

.approval-sheet-cancel {
  flex: 1;
  height: 80rpx;
  border-radius: 20rpx;
  border: 1rpx solid var(--ts-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--ts-font-body);
  color: var(--ts-text-secondary);
}

.approval-sheet-confirm {
  flex: 2;
  height: 80rpx;
  border-radius: 20rpx;
  background: var(--ts-primary);
  color: #fff;
  font-size: var(--ts-font-title1);
  font-weight: var(--weight-semibold);
  display: flex;
  align-items: center;
  justify-content: center;
}

.approval-sheet-confirm:active {
  opacity: 0.8;
}
