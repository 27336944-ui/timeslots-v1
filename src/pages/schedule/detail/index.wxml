<view class="page">
  <privacy-agreement />
  <block wx:if="{{mode === 'create' || mode === 'edit'}}">
    <view class="form-group">
      <!-- Core fields -->
      <view class="form-item">
        <view class="form-label">标题</view>
        <input class="form-input" value="{{formTitle}}" bindinput="onTitleInput" placeholder="日程标题" />
      </view>

      <view class="form-row">
        <view class="form-item form-item-half">
          <view class="form-label">日期</view>
          <picker mode="date" value="{{formDate}}" bindchange="onDateChange">
            <view class="form-picker">
              <text class="{{formDate ? 'form-picker-text' : 'form-picker-hint'}}">{{formDate || '选择日期'}}</text>
              <text class="form-picker-arrow">›</text>
            </view>
          </picker>
        </view>

        <view class="form-item form-item-half">
          <view class="form-label">时间</view>
          <view class="form-time-group">
            <picker mode="time" value="{{formStartTime}}" bindchange="onStartTimeChange">
              <text class="{{formStartTime ? 'form-picker-text' : 'form-picker-hint'}}">{{formStartTime || '开始'}}</text>
            </picker>
            <text class="form-time-sep">—</text>
            <picker mode="time" value="{{formEndTime}}" bindchange="onEndTimeChange">
              <text class="{{formEndTime ? 'form-picker-text' : 'form-picker-hint'}}">{{formEndTime || '结束'}}</text>
            </picker>
          </view>
        </view>
      </view>

      <!-- Toggle more options -->
      <view class="more-toggle" bindtap="onToggleMoreOptions">
        <text>{{showMoreOptions ? '收起更多选项' : '更多选项'}}</text>
        <text class="more-toggle-arrow {{showMoreOptions ? 'more-toggle-arrow-up' : ''}}">›</text>
      </view>

      <!-- Optional fields (collapsible) -->
      <block wx:if="{{showMoreOptions || mode === 'edit'}}">
        <view class="form-item">
          <view class="form-label">地点</view>
          <input class="form-input" value="{{formLocation}}" bindinput="onLocationInput" placeholder="日程地点" />
        </view>

        <view class="form-item">
          <view class="form-label">备注</view>
          <textarea class="form-textarea" value="{{formDescription}}" bindinput="onDescriptionInput" placeholder="添加备注" />
        </view>

        <view class="form-item">
          <view class="form-label">分类</view>
          <view class="form-btn-group">
            <view class="form-btn {{formCategory === 'work' ? 'active-work' : ''}}" bindtap="onCategoryChange" data-value="work">工作</view>
            <view class="form-btn {{formCategory === 'life' ? 'active-life' : ''}}" bindtap="onCategoryChange" data-value="life">生活</view>
            <view class="form-btn {{formCategory === 'private' ? 'active-private' : ''}}" bindtap="onCategoryChange" data-value="private">私有</view>
          </view>
        </view>

        <view class="form-item">
          <view class="form-label">可见性</view>
          <view class="form-btn-group">
            <view class="form-btn {{formNature === 'PUBLIC' ? 'active-public' : ''}}" bindtap="onNatureChange" data-value="PUBLIC">公开</view>
            <view class="form-btn {{formNature === 'PRIVATE' ? 'active-private' : ''}}" bindtap="onNatureChange" data-value="PRIVATE">私有</view>
            <view class="form-btn {{formNature === 'CIRCLE_ONLY' ? 'active-circle' : ''}}" bindtap="onNatureChange" data-value="CIRCLE_ONLY">圈子可见</view>
          </view>
        </view>

        <view wx:if="{{formNature === 'CIRCLE_ONLY' && circleOptions.length > 0}}" class="form-item">
          <view class="form-label">选择圈子</view>
          <picker mode="selector" range="{{circleOptions}}" range-key="name" bindchange="onCircleChange">
            <view class="form-picker">
              <text class="{{formCircleId ? 'form-picker-text' : 'form-picker-hint'}}">{{formCircleLabel || '选择圈子'}}</text>
              <text class="form-picker-arrow">›</text>
            </view>
          </picker>
        </view>

        <view class="form-item">
          <view class="form-label">优先级</view>
          <view class="form-btn-group">
            <view class="form-btn form-btn-sm {{formPriority === 'high' ? 'active-high' : ''}}" bindtap="onPriorityChange" data-value="high">高</view>
            <view class="form-btn form-btn-sm {{formPriority === 'medium' ? 'active-medium' : ''}}" bindtap="onPriorityChange" data-value="medium">中</view>
            <view class="form-btn form-btn-sm {{formPriority === 'low' ? 'active-low' : ''}}" bindtap="onPriorityChange" data-value="low">低</view>
          </view>
        </view>

        <view class="form-item">
          <view class="form-label">周期</view>
          <view class="form-btn-group form-btn-group-wrap">
            <view class="form-btn form-btn-sm {{formRecurrence === 'none' ? 'active-none' : ''}}" bindtap="onRecurrenceChange" data-value="none">不重复</view>
            <view class="form-btn form-btn-sm {{formRecurrence === 'daily' ? 'active-daily' : ''}}" bindtap="onRecurrenceChange" data-value="daily">每天</view>
            <view class="form-btn form-btn-sm {{formRecurrence === 'weekly' ? 'active-weekly' : ''}}" bindtap="onRecurrenceChange" data-value="weekly">每周</view>
            <view class="form-btn form-btn-sm {{formRecurrence === 'monthly' ? 'active-monthly' : ''}}" bindtap="onRecurrenceChange" data-value="monthly">每月</view>
            <view class="form-btn form-btn-sm {{formRecurrence === 'yearly' ? 'active-yearly' : ''}}" bindtap="onRecurrenceChange" data-value="yearly">每年</view>
          </view>
        </view>

        <view class="form-item">
          <view class="form-label">联系人</view>
          <input class="form-input" value="{{formContacts}}" bindinput="onContactsInput" placeholder="参与人姓名" />
        </view>

        <view class="form-item">
          <view class="form-label">天气</view>
          <input class="form-input" value="{{formWeather}}" bindinput="onWeatherInput" placeholder="预留字段" />
        </view>

        <view class="form-item">
          <view class="form-label">提醒</view>
          <picker mode="selector" range="{{reminderOptions}}" range-key="label" value="{{formReminderIndex}}" bindchange="onReminderChange">
            <view class="form-picker">
              <text class="{{formReminderLead > 0 ? 'form-picker-text' : 'form-picker-hint'}}">{{reminderLabel}}</text>
              <text class="form-picker-arrow">›</text>
            </view>
          </picker>
        </view>

        <view class="form-item" bindtap="onTaskPickerTap">
          <view class="form-label">关联任务</view>
          <view class="form-picker">
            <text class="{{formTaskId ? 'form-picker-text' : 'form-picker-hint'}}">{{formTaskTitle || '选择关联任务（可选）'}}</text>
            <view wx:if="{{formTaskId}}" class="form-clear-btn" catchtap="onClearTask">✕</view>
          </view>
        </view>

        <view class="form-item">
          <view class="form-label">状态</view>
          <view class="form-status">
            <view class="status-btn {{formStatus === 'todo' ? 'active-todo' : ''}}" bindtap="onStatusChange" data-status="todo">待办</view>
            <view class="status-btn {{formStatus === 'done' ? 'active-done' : ''}}" bindtap="onStatusChange" data-status="done">已完成</view>
          </view>
        </view>
      </block>
    </view>

    <button class="save-btn" bindtap="onSave">{{mode === 'create' ? '创建' : '保存'}}</button>
    <button wx:if="{{mode === 'edit'}}" class="delete-btn" bindtap="onDelete">删除日程</button>
  </block>

  <block wx:if="{{mode === 'view'}}">
    <view class="view-hero">
      <view class="view-title">{{viewTitle}}</view>
      <view class="view-time">{{viewTimeRange}}</view>
      <view wx:if="{{viewStatus}}" class="view-status {{viewStatus === 'todo' ? 'view-status-todo' : 'view-status-done'}}">{{viewStatus === 'todo' ? '待办' : '已完成'}}</view>
    </view>

    <view class="view-section">
      <view wx:if="{{viewLocation}}" class="view-row">
        <text class="view-label">位置</text>
        <text class="view-value">{{viewLocation}}</text>
      </view>
      <view wx:if="{{viewDescription}}" class="view-row">
        <text class="view-label">备注</text>
        <text class="view-value">{{viewDescription}}</text>
      </view>
      <view wx:if="{{viewTaskTitle}}" class="view-row" bindtap="onViewTaskTap">
        <text class="view-label">任务</text>
        <text class="view-value view-task-link">{{viewTaskTitle}}</text>
      </view>
    </view>

    <view class="view-section view-section-secondary">
      <view wx:if="{{viewCategory}}" class="view-row">
        <text class="view-label">分类</text>
        <text class="view-value">{{viewCategory}}</text>
      </view>
      <view wx:if="{{viewNature}}" class="view-row">
        <text class="view-label">可见</text>
        <text class="view-value">{{viewNature}}{{viewCircleName ? ' · ' + viewCircleName : ''}}</text>
      </view>
      <view wx:if="{{viewPriority}}" class="view-row">
        <text class="view-label">优先级</text>
        <text class="view-value">{{viewPriority}}</text>
      </view>
      <view wx:if="{{viewRecurrence && viewRecurrence !== '不重复'}}" class="view-row">
        <text class="view-label">重复</text>
        <text class="view-value">{{viewRecurrence}}</text>
      </view>
      <view wx:if="{{viewContacts}}" class="view-row">
        <text class="view-label">联系人</text>
        <text class="view-value">{{viewContacts}}</text>
      </view>
      <view wx:if="{{viewWeather}}" class="view-row">
        <text class="view-label">天气</text>
        <text class="view-value">{{viewWeather}}</text>
      </view>
      <view wx:if="{{viewReminder}}" class="view-row">
        <text class="view-label">提醒</text>
        <text class="view-value">{{viewReminder}}</text>
      </view>
      <view class="view-row view-row-created">
        <text class="view-label">创建</text>
        <text class="view-value">{{viewCreatedAt}}</text>
      </view>
    </view>

    <button class="edit-btn" bindtap="onEditTap">编辑</button>
    <button class="delete-btn" bindtap="onDelete">删除日程</button>
    <button class="approve-btn" bindtap="onApproveTap">发起审批</button>
  </block>

  <!-- Task picker modal -->
  <view wx:if="{{showTaskPicker}}" class="modal-overlay" bindtap="onTaskPickerClose">
    <view class="modal-content" catchtap="noop">
      <view class="modal-header">
        <text class="modal-title">选择关联任务</text>
        <text class="modal-close" bindtap="onTaskPickerClose">关闭</text>
      </view>
      <scroll-view scroll-y class="modal-list">
        <view wx:for="{{taskOptions}}" wx:key="id" class="modal-item" data-id="{{item.id}}" data-title="{{item.title}}" bindtap="onSelectTask">
          <text class="modal-item-title">{{item.title}}</text>
          <text class="modal-item-status">{{item.status === 'in_progress' ? '进行中' : '待办'}}</text>
        </view>
        <view wx:if="{{taskOptions.length === 0}}" class="modal-empty">暂无待办任务</view>
      </scroll-view>
    </view>
  </view>

  <!-- Approval BottomSheet -->
  <bottom-sheet visible="{{showApprovalSheet}}" bind:close="onApprovalClose" height="auto">
    <view class="approval-sheet-body">
      <view class="approval-sheet-title">发起审批</view>

      <view class="approval-sheet-section">
        <view class="approval-sheet-label">手机号</view>
        <view class="approval-sheet-row">
          <input class="approval-sheet-input" value="{{approvalPhoneInput}}" bindinput="onApprovalPhoneInput" placeholder="输入手机号" type="number" maxlength="11" />
          <view class="approval-sheet-add-btn" bindtap="onApprovalAddPhone">添加</view>
        </view>
      </view>

      <view wx:if="{{approvalPhoneList.length > 0}}" class="approval-sheet-tags">
        <view wx:for="{{approvalPhoneList}}" wx:key="*this" class="approval-sheet-tag">
          <text>{{item}}</text>
          <text class="approval-sheet-tag-close" data-value="{{item}}" bindtap="onApprovalRemovePhone">✕</text>
        </view>
      </view>

      <view class="approval-sheet-actions">
        <view class="approval-sheet-cancel" bindtap="onApprovalClose">取消</view>
        <view class="approval-sheet-confirm" bindtap="onApprovalSubmit">确认发起</view>
      </view>
    </view>
  </bottom-sheet>
</view>
