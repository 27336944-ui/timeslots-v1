.page {
  min-height: 100vh;
  background: var(--ts-bg-page);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 28rpx;
}

.about-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.about-logo {
  font-size: var(--ts-font-hero);
  margin-bottom: 16rpx;
}

.about-name {
  font-size: var(--ts-font-title);
  font-weight: var(--weight-bold);
  color: var(--ts-text-primary);
  margin-bottom: 8rpx;
}

.about-version {
  font-size: var(--ts-font-callout);
  color: var(--ts-text-placeholder);
  margin-bottom: 12rpx;
}

.about-desc {
  font-size: var(--ts-font-body);
  color: var(--ts-text-placeholder);
}

.about-section {
  width: 100%;
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  overflow: hidden;
  margin-bottom: 60rpx;
}

.about-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--ts-border-light);
}

.about-row:last-child {
  border-bottom: none;
}

.about-row-text {
  font-size: var(--ts-font-body);
  color: var(--ts-text-link);
}

.about-row-arrow {
  font-size: var(--ts-font-callout);
  color: var(--ts-text-placeholder);
}

.about-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: auto;
  padding-bottom: 40rpx;
}

.about-footer-text {
  font-size: var(--ts-font-small);
  color: var(--ts-text-placeholder);
  margin-bottom: 4rpx;
}