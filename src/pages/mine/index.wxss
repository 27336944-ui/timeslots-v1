
page {
  background-color: var(--ts-bg-page);
  font-family: var(--ts-font-family);
}

/* ===== Top Bar ===== */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 96rpx 32rpx 16rpx;
  position: sticky;
  top: 0;
  background: var(--ts-surface-tertiary);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  z-index: 10;
}

.top-bar-title {
  font-size: 68rpx;
  font-weight: 700;
  color: var(--ts-text-primary);
  letter-spacing: -0.6rpx;
}

.top-bar-spacer {
  width: 88rpx;
  height: 88rpx;
}

/* ===== Profile Card ===== */
.profile-card {
  margin: 16rpx 32rpx 40rpx;
  background: var(--ts-bg-blur);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-radius: 64rpx;
  padding: 40rpx 40rpx 32rpx;
  transition: transform 0.15s ease;
  box-shadow: var(--ts-shadow-card-raised);
}

.profile-card:active {
  transform: scale(0.98);
}

.profile-top {
  display: flex;
  align-items: center;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background-color: var(--ts-primary);
  color: var(--ts-text-on-brand);
  font-size: 48rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 28rpx;
}

.avatar-img {
  overflow: hidden;
  padding: 0;
  background-color: transparent !important;
}

.avatar-img-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-size: var(--ts-font-hero-title);
  font-weight: 600;
  color: var(--ts-text-primary);
  line-height: 1.3;
}

.profile-desc {
  font-size: var(--ts-font-callout);
  color: var(--ts-text-tertiary);
  margin-top: 4rpx;
}

.profile-arrow {
  font-size: var(--ts-font-display);
  color: var(--ts-text-placeholder);
  flex-shrink: 0;
  line-height: 1;
}

.profile-divider {
  height: 2rpx;
  background: var(--ts-border);
  margin: 28rpx 0;
}

.profile-stats {
  display: flex;
  justify-content: space-around;
}

.profile-stat {
  text-align: center;
  flex: 1;
}

.profile-stat-value {
  font-size: var(--ts-font-hero-title);
  font-weight: 700;
  color: var(--ts-primary);
}

.profile-stat-value.stat-warning {
  color: var(--ts-priority-high);
}

.profile-stat-label {
  font-size: var(--ts-font-small);
  color: var(--ts-text-tertiary);
  margin-top: 4rpx;
}

/* ===== Section Header ===== */
.section-header {
  padding: 40rpx 40rpx 16rpx;
  font-size: var(--ts-font-callout);
  font-weight: 600;
  color: var(--ts-text-tertiary);
  text-transform: uppercase;
  letter-spacing: 0.4rpx;
}

/* ===== List Group ===== */
.list-group {
  margin: 0 32rpx;
  background: var(--ts-bg-card);
  border-radius: 40rpx;
  overflow: hidden;
}

.list-group + .list-group {
  margin-top: 40rpx;
}

.list-cell {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  min-height: 96rpx;
  transition: background 0.12s ease;
}

.list-cell:active {
  background: var(--ts-bg-disabled);
}

.list-cell + .list-cell {
  border-top: 1rpx solid var(--ts-border-light);
}

.cell-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--ts-radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--ts-font-title);
  flex-shrink: 0;
  margin-right: 24rpx;
}

.cell-icon.blue {
  background: var(--ts-primary-bg);
  color: var(--ts-primary);
}

.cell-icon.green {
  background: var(--ts-category-life-bg);
  color: var(--ts-status-done);
}

.cell-icon.amber {
  background: var(--ts-category-private-bg);
  color: var(--ts-warning);
}

.cell-icon.gray {
  background: var(--ts-bg-disabled);
  color: var(--ts-text-secondary);
}

.cell-label {
  flex: 1;
  font-size: var(--ts-font-display);
  color: var(--ts-text-primary);
  line-height: 1.3;
}

.cell-label-tag {
  font-size: var(--ts-font-body);
  color: var(--ts-text-tertiary);
}

.cell-label-danger {
  color: var(--ts-danger);
}

.cell-label-bold {
  font-weight: 600;
}

.cell-arrow {
  font-size: var(--ts-font-title);
  color: var(--ts-text-placeholder);
  margin-left: 16rpx;
  line-height: 1;
}

/* ===== Footer ===== */
.page-footer {
  text-align: center;
  padding: 80rpx 0 64rpx;
  font-size: var(--ts-font-caption);
  color: var(--ts-text-placeholder);
}

/* ===== Profile Subpage ===== */
.subpage-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--ts-bg-page);
  z-index: 100;
  transform: translateX(100%);
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.subpage-active {
  transform: translateX(0);
}

.subpage-header {
  display: flex;
  align-items: center;
  padding: 96rpx 32rpx 16rpx;
  background: var(--ts-surface-tertiary);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  position: sticky;
  top: 0;
  z-index: 10;
}

.subpage-back {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--ts-font-hero-title);
  color: var(--ts-primary);
  border-radius: 50%;
  transition: background 0.12s ease;
}

.subpage-back:active {
  background: var(--ts-bg-disabled);
}

.subpage-title {
  font-size: var(--ts-font-display);
  font-weight: 600;
  color: var(--ts-text-primary);
  margin-left: 8rpx;
}

.subpage-body {
  flex: 1;
  overflow-y: auto;
  padding-top: 16rpx;
  -webkit-overflow-scrolling: touch;
}

/* ===== Edit Card ===== */
.edit-card {
  margin: 16rpx 32rpx 40rpx;
  background: var(--ts-bg-card);
  border-radius: 40rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
}

.edit-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background-color: var(--ts-primary);
  color: var(--ts-text-on-brand);
  font-size: 56rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 28rpx;
  overflow: hidden;
}

.edit-info {
  flex: 1;
  min-width: 0;
}

.edit-name {
  font-size: var(--ts-font-hero-title);
  font-weight: 600;
  color: var(--ts-text-primary);
}

.edit-hint {
  font-size: var(--ts-font-callout);
  color: var(--ts-primary);
  margin-top: 4rpx;
}

/* ===== Modal ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--ts-overlay-bg);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal {
  background: var(--ts-bg-card);
  border-radius: 48rpx;
  padding: 64rpx 48rpx 40rpx;
  width: 620rpx;
  max-width: 90%;
  animation: modalIn 0.2s ease-out;
}

@keyframes modalIn {
  from {
    opacity: 0;
    transform: scale(0.92);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.modal-title {
  font-size: var(--ts-font-display);
  font-weight: 600;
  color: var(--ts-text-primary);
  text-align: center;
  margin-bottom: 16rpx;
}

.modal-desc {
  font-size: var(--ts-font-body);
  color: var(--ts-text-secondary);
  text-align: center;
  line-height: 1.5;
  margin-bottom: 48rpx;
}

.modal-actions {
  display: flex;
  flex-direction: column;
  gap: var(--ts-space-md);
}

.modal-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 96rpx;
  font-size: var(--ts-font-title);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.modal-btn:active {
  opacity: 0.7;
}

.modal-btn.danger {
  background-color: var(--ts-danger);
  color: #fff;
}

.modal-btn.primary {
  background-color: var(--ts-primary);
  color: #fff;
}

.modal-btn.cancel {
  background-color: var(--ts-bg-disabled);
  color: var(--ts-text-primary);
}

.modal-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid var(--ts-border);
  border-radius: var(--ts-radius-xxl);
  padding: 0 48rpx;
  font-size: var(--ts-font-body);
  background: var(--ts-bg-disabled);
  margin-bottom: 64rpx;
  box-sizing: border-box;
}

/* ===== Login Section ===== */
.login-section {
  margin: 16rpx 32rpx 40rpx;
  background: var(--ts-bg-blur);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-radius: 64rpx;
  padding: 48rpx 40rpx;
  text-align: center;
  box-shadow: var(--ts-shadow-card-raised);
}

.login-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--ts-text-primary);
  margin-bottom: 12rpx;
}

.login-desc {
  font-size: var(--ts-font-callout);
  color: var(--ts-text-tertiary);
  margin-bottom: 40rpx;
}

.login-form {
  display: flex;
  flex-direction: column;
  gap: var(--ts-space-lg);
}

.login-input {
  width: 100%;
  height: 88rpx;
  border-radius: 48rpx;
  padding: 0 32rpx;
  font-size: var(--ts-font-title);
  background: var(--ts-bg-disabled);
  text-align: center;
  box-sizing: border-box;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 48rpx;
  font-size: var(--ts-font-title);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  background: var(--ts-bg-disabled);
  color: var(--ts-text-primary);
}

.login-btn:active {
  opacity: 0.7;
}

.login-btn[type="primary"] {
  background: var(--ts-primary);
  color: var(--ts-text-on-brand);
}

.login-divider {
  font-size: var(--ts-font-caption);
  color: var(--ts-text-tertiary);
  margin: 8rpx 0;
}

.wx-login-btn {
  background: var(--ts-primary) !important;
  color: var(--ts-text-on-brand) !important;
}
