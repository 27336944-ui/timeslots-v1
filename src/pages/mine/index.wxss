.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 32rpx;
  min-height: 100vh;
  background-color: var(--ts-bg-page);
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  margin-bottom: 16rpx;
}

.top-bar-title {
  font-size: var(--ts-font-large-title);
  font-weight: var(--weight-bold);
  color: #333;
}

.top-bar-actions {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.top-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--ts-font-title1);
}

.top-btn-search {
  background: var(--ts-bg-disabled);
  color: #666;
  font-size: var(--ts-font-body);
}

.top-btn-search:active {
  background: var(--ts-border);
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  width: 100%;
  margin-bottom: 16rpx;
}

.search-input {
  flex: 1;
  height: 64rpx;
  border-radius: 32rpx;
  background: var(--ts-bg-disabled);
  padding: 0 24rpx;
  font-size: var(--ts-font-body);
  color: #333;
}

.search-cancel {
  font-size: var(--ts-font-callout);
  color: var(--ts-primary);
  padding: 8rpx;
}

.profile {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: var(--ts-primary);
  color: #fff;
  font-size: 40rpx;
  font-weight: var(--weight-semibold);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.avatar-img {
  border-radius: 50%;
  overflow: hidden;
}

.avatar-placeholder {
  background-color: var(--ts-text-placeholder);
}

.nickname {
  font-size: 36rpx;
  font-weight: var(--weight-semibold);
  color: #333;
}

.login-form {
  width: 100%;
  max-width: 500rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  border: 1rpx solid var(--ts-border);
  border-radius: var(--ts-radius-md);
  padding: 0 24rpx;
  font-size: var(--ts-font-body);
  background: var(--ts-bg-card);
  box-sizing: border-box;
}

.btn {
  width: 100%;
  height: 88rpx;
  border-radius: var(--ts-radius-md);
  font-size: var(--ts-font-title1);
  font-weight: var(--weight-semibold);
  display: flex;
  align-items: center;
  justify-content: center;
}

.section-title {
  font-size: var(--ts-font-caption);
  font-weight: var(--weight-semibold);
  letter-spacing: var(--ts-ls-form-label);
  text-transform: uppercase;
  color: #999;
  margin-bottom: 12rpx;
}

.btn-primary {
  background-color: var(--ts-primary);
  color: #fff;
}

.btn-wechat {
  background-color: var(--ts-status-done);
  color: #fff;
}

.btn-danger {
  background-color: var(--ts-danger);
  color: #fff;
}

.divider-text {
  text-align: center;
  color: #ccc;
  font-size: var(--ts-font-body);
  margin: 24rpx 0;
}

.stats-section {
  display: flex;
  gap: 16rpx;
  width: 100%;
  max-width: 500rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  flex: 1;
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--ts-card-shadow);
}

.stat-value {
  font-size: 40rpx;
  font-weight: var(--weight-bold);
  color: var(--ts-primary);
}

.stat-label {
  font-size: var(--ts-font-tiny);
  color: var(--ts-text-tertiary);
  margin-top: 8rpx;
}

.stat-warning {
  color: var(--ts-priority-high) !important;
}

.settings-section {
  width: 100%;
  max-width: 500rpx;
  margin-bottom: 32rpx;
}

.settings-row {
  display: flex;
  align-items: center;
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: 28rpx 24rpx;
}

.settings-row:active {
  background: var(--ts-bg-disabled);
}

.settings-icon {
  font-size: var(--ts-font-title1);
  margin-right: 16rpx;
}

.settings-text {
  flex: 1;
  font-size: var(--ts-font-title1);
  color: #333;
}

.settings-arrow {
  font-size: var(--ts-font-title1);
  color: #ccc;
}

.logout-section {
  margin-top: 48rpx;
  width: 100%;
  max-width: 500rpx;
}

.delete-row {
  margin-top: 24rpx;
  text-align: center;
}

.btn-text {
  background: none;
  border: none;
  color: #999;
  font-size: var(--ts-font-callout);
  padding: 0;
  line-height: 1;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal {
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: 48rpx 32rpx;
  width: 600rpx;
  max-width: 90%;
}

.modal-title {
  font-size: var(--ts-font-large-title);
  font-weight: var(--weight-semibold);
  color: #333;
  margin-bottom: 16rpx;
  text-align: center;
}

.modal-desc {
  font-size: var(--ts-font-body);
  color: #666;
  margin-bottom: 24rpx;
  text-align: center;
  line-height: 1.6;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid var(--ts-border);
  border-radius: var(--ts-radius-md);
  padding: 0 24rpx;
  font-size: var(--ts-font-body);
  background: var(--ts-bg-disabled);
  margin-bottom: 32rpx;
  box-sizing: border-box;
}

.modal-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.modal-btn {
  width: 100%;
  height: 80rpx;
  font-size: var(--ts-font-title1);
  border-radius: var(--ts-radius-md);
}

.btn-secondary {
  background-color: var(--ts-border);
  color: #333;
}
