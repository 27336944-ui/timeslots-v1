.page {
  min-height: 100vh;
  background: var(--ts-bg-page);
  padding: 28rpx;
}

.form-group {
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: var(--ts-card-padding);
  margin-bottom: var(--ts-card-gap);
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: var(--ts-font-caption);
  font-weight: var(--weight-semibold);
  letter-spacing: var(--ts-ls-form-label);
  text-transform: uppercase;
  color: #999;
  margin-bottom: 10rpx;
}

.form-hint {
  display: block;
  font-size: var(--ts-font-tiny);
  color: var(--ts-text-placeholder);
  margin-top: 8rpx;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 72rpx;
  border: 1rpx solid var(--ts-border);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: var(--ts-font-body);
  color: #333;
}

.form-picker-text {
  color: #333;
}

.form-picker-arrow {
  font-size: var(--ts-font-callout);
  color: #ccc;
}

.form-btn-group {
  display: flex;
  gap: var(--ts-space-sm);
}

.form-btn {
  flex: 1;
  padding: 12rpx 28rpx;
  border-radius: var(--ts-radius-md);
  font-size: var(--ts-font-callout);
  border: 1rpx solid var(--ts-border);
  color: #999;
  background: var(--ts-bg-card);
  text-align: center;
}

.form-btn.active-public {
  border-color: var(--ts-primary);
  color: var(--ts-primary);
  background: var(--ts-primary-bg);
}

.form-btn.active-private {
  border-color: var(--ts-priority-medium);
  color: var(--ts-priority-medium);
  background: #fffbe6;
}

.form-btn.active-circle {
  border-color: var(--ts-primary);
  color: var(--ts-primary);
  background: var(--ts-primary-bg);
}

.save-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 20rpx;
  background: var(--ts-primary);
  color: #fff;
  font-size: var(--ts-font-title1);
  font-weight: var(--weight-semibold);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.save-btn:active {
  opacity: 0.8;
}
