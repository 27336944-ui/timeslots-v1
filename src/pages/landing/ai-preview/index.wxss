.page {
  padding: 40rpx 32rpx;
  min-height: 100vh;
  background: var(--ts-bg-page);
}

.header {
  text-align: center;
  margin-bottom: 48rpx;
}

.title {
  font-size: var(--ts-font-display);
  font-weight: var(--weight-bold);
  color: var(--ts-text-primary);
}

.subtitle {
  display: block;
  font-size: var(--ts-font-body);
  color: var(--ts-text-tertiary);
  margin-top: 12rpx;
}

.input-area {
  margin-bottom: 40rpx;
}

.input {
  width: 100%;
  min-height: 160rpx;
  padding: 28rpx;
  font-size: var(--ts-font-body);
  background: var(--ts-bg-card);
  border-radius: var(--ts-radius-lg);
  border: 2rpx solid var(--ts-border);
  box-sizing: border-box;
}

.decompose-btn {
  margin-top: 24rpx;
  width: 100%;
}

.result {
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: var(--ts-space-xl);
  margin-top: 16rpx;
}

.task-title {
  font-size: var(--ts-font-display);
  font-weight: var(--weight-semibold);
  color: var(--ts-text-primary);
  margin-bottom: 28rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid var(--ts-border-light);
}

.step {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.step-number {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--ts-primary);
  color: var(--ts-bg-card);
  font-size: var(--ts-font-callout);
  text-align: center;
  line-height: 44rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.step-content {
  flex: 1;
}

.step-text {
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
}

.step-time {
  display: block;
  font-size: var(--ts-font-callout);
  color: var(--ts-text-tertiary);
  margin-top: 4rpx;
}

.step-dep {
  margin-left: 12rpx;
}

.dep-label {
  font-size: var(--ts-font-caption);
  color: var(--ts-warning);
  background: var(--ts-badge-yellow-bg);
  padding: 4rpx 12rpx;
  border-radius: var(--ts-radius-sm);
}

.rationale {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid var(--ts-border-light);
}

.rationale-label {
  font-size: var(--ts-font-body);
  font-weight: var(--weight-semibold);
  color: var(--ts-text-secondary);
}

.rationale-text {
  display: block;
  font-size: var(--ts-font-body);
  color: var(--ts-text-tertiary);
  margin-top: 8rpx;
  line-height: 1.6;
}

.cta {
  margin-top: 48rpx;
  text-align: center;
}

.register-btn {
  width: 100%;
  margin-bottom: 20rpx;
}

.login-btn {
  width: 100%;
  font-size: var(--ts-font-body);
}