<view class="page">
  <privacy-agreement />
  <view wx:if="{{loading && !currentRequest}}" class="skeleton-wrap">
    <skeleton rowCount="4" />
  </view>

  <view wx:if="{{!loading && !currentRequest}}" class="empty-state">
    <view class="empty-icon"></view>
    <text class="empty-text">暂无审批详情</text>
  </view>

  <view wx:if="{{currentRequest}}" class="approval-card">
    <view class="block-title">{{currentRequest.title}}</view>
    <view class="block-time">{{currentRequest.startTime}} - {{currentRequest.endTime}}</view>
    <view wx:if="{{currentRequest.description}}" class="block-desc">{{currentRequest.description}}</view>
  </view>

  <view wx:if="{{currentRequest && currentRequest.isInitiator}}" class="approval-card">
    <view class="section-title">受邀人 ({{currentRequest.recipients.length}})</view>
    <view wx:for="{{currentRequest.recipients}}" wx:key="id" class="recipient-item">
      <view>
        <text class="recipient-info">{{item.contactValue || item.contactType}}</text>
        <text class="recipient-status-{{item.status}}">{{item.status === 'pending' ? '等待中' : item.status === 'approved' ? '已同意' : item.status === 'rejected' ? '已拒绝' : '已过期'}}</text>
      </view>
      <button wx:if="{{item.status === 'pending' || item.status === 'expired'}}" class="btn-resend" bindtap="onResend" data-recipient-id="{{item.id}}">补发</button>
    </view>
  </view>

  <view wx:if="{{currentRequest && !currentRequest.isInitiator}}" class="action-bar">
    <button class="btn-reject" bindtap="onReject">拒绝</button>
    <button class="btn-approve" bindtap="onApprove">同意</button>
  </view>
</view>
