page {
  min-height: 100vh;
  background: var(--ts-bg-page);
}

.approval-card {
  background: var(--ts-bg-card);
  margin: 20rpx;
  padding: var(--ts-card-padding);
  border-radius: var(--ts-card-radius);
  box-shadow: var(--ts-card-shadow);
}

.section-title {
  font-size: var(--ts-font-body);
  font-weight: var(--weight-medium);
  color: #333;
  margin-bottom: 16rpx;
}

.block-title {
  font-size: var(--ts-font-large-title);
  font-weight: var(--weight-semibold);
  color: #333;
  margin-bottom: 12rpx;
}

.block-time {
  font-size: var(--ts-font-callout);
  color: #666;
  margin-bottom: 8rpx;
}

.block-desc {
  font-size: var(--ts-font-body);
  color: #555;
  margin-top: 12rpx;
  line-height: 1.6;
}

.recipient-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--ts-border-light);
}

.recipient-info {
  font-size: var(--ts-font-body);
  color: #333;
}

.recipient-status-approved {
  color: var(--ts-status-done);
  font-size: var(--ts-font-tiny);
}

.recipient-status-rejected {
  color: var(--ts-danger);
  font-size: var(--ts-font-tiny);
}

.recipient-status-pending {
  color: #f5a623;
  font-size: var(--ts-font-tiny);
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  background: var(--ts-bg-card);
  border-top: 1rpx solid var(--ts-border-light);
}

.btn-approve, .btn-reject {
  flex: 1;
  font-size: var(--ts-font-title1);
  font-weight: var(--weight-semibold);
  padding: 24rpx 0;
  text-align: center;
  border-radius: var(--ts-radius-md);
}

.btn-approve {
  background: var(--ts-status-done);
  color: #fff;
}

.btn-reject {
  background: var(--ts-bg-disabled);
  color: #999;
}

.btn-resend {
  font-size: var(--ts-font-tiny);
  color: var(--ts-primary);
  padding: 8rpx 16rpx;
}

.status-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx;
  margin: 20rpx;
  border-radius: var(--ts-radius-md);
  font-size: var(--ts-font-body);
}

.status-pending { background: #fff8e5; color: #f5a623; }
.status-partial { background: #eef1ff; color: var(--ts-primary); }
.status-completed { background: #e8f8ee; color: var(--ts-status-done); }
.status-cancelled { background: var(--ts-bg-disabled); color: #999; }

.skeleton-wrap {
  padding: 32rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: var(--ts-font-title1);
  color: var(--ts-text-tertiary);
}
