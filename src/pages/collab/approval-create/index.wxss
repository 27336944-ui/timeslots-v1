.page {
  min-height: 100vh;
  background: var(--ts-bg-page);
}

.section {
  background: var(--ts-bg-card);
  margin: 20rpx;
  padding: var(--ts-card-padding);
  border-radius: var(--ts-card-radius);
}

.section-title {
  font-size: var(--ts-font-title1);
  font-weight: var(--weight-medium);
  color: #333;
  margin-bottom: 16rpx;
}

.block-info {
  font-size: var(--ts-font-title1);
  color: #333;
  margin-bottom: 8rpx;
}

.block-time {
  font-size: var(--ts-font-callout);
  color: #999;
}

.tab-bar {
  display: flex;
  margin-bottom: 16rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: var(--ts-font-callout);
  color: #666;
  border-bottom: 1rpx solid var(--ts-border-light);
}

.tab-item.active {
  color: var(--ts-primary);
  border-bottom-color: var(--ts-primary);
  font-weight: var(--weight-medium);
}

.recipient-input-area {
  margin-top: 12rpx;
}

.phone-input {
  width: 100%;
  padding: 16rpx;
  border: 1rpx solid var(--ts-border-light);
  border-radius: var(--ts-radius-md);
  font-size: var(--ts-font-body);
  margin-bottom: 12rpx;
  box-sizing: border-box;
}

.recipient-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: var(--ts-primary-bg);
  color: var(--ts-primary);
  border-radius: var(--ts-radius-sm);
  font-size: var(--ts-font-tiny);
  margin: 4rpx;
}

.btn-add {
  width: 100%;
  margin-top: 16rpx;
}

.btn-primary {
  width: 100%;
  font-size: var(--ts-font-title1);
  font-weight: var(--weight-semibold);
  padding: 24rpx 0;
  text-align: center;
  color: #fff;
  background: var(--ts-primary);
  border-radius: var(--ts-radius-md);
  margin-top: 20rpx;
}
