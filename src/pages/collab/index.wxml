<scroll-view class="page" scroll-y refresher-enabled refresher-triggered="{{loading}}" bindrefresherrefresh="onRefresh">
  <privacy-agreement />
  <compact-header date="{{headerDateStr}}" week-days="{{weekDays}}" selected-day="{{selectedDay}}" bind:search="onSearchTap" bind:plus="onPlusTap" bind:weekdaytap="onWeekDayTap">
    <view slot="overview">
      <text class="ov-line">
        <text>待回应{{pendingList.length}}条邀约</text>
        <text wx:if="{{initiatedList.length > 0}}">，已发出{{initiatedList.length}}条</text>
      </text>
    </view>
  </compact-header>
  <view wx:if="{{showSearch}}" class="search-bar">
    <input class="search-input" adjust-position="{{true}}" cursor-spacing="{{100}}" placeholder="搜索邀约请求…" value="{{searchKeyword}}" bindinput="onSearchInput" focus="{{true}}" />
    <view class="search-cancel" bindtap="onSearchClose">取消</view>
  </view>

  <!-- Sub tabs -->
  <view class="tabs-row">
    <view class="tab {{activeTab === 'pending' ? 'tab-active' : ''}}" bindtap="onTabPending">待赴约</view>
    <view class="tab {{activeTab === 'initiated' ? 'tab-active' : ''}}" bindtap="onTabInitiated">已发出</view>
  </view>

  <!-- Pending tab -->
  <view wx:if="{{activeTab === 'pending'}}">
    <state-view wx:if="{{pendingList.length === 0 && !loading}}" empty="{{true}}" emptyText="还没有人分享给你" actionText="分享时间名片开始协作" bind:action="onShareNamecard" />

    <view wx:for="{{showSearch ? filteredPendingList : pendingList}}" wx:key="recipientId" class="approval-card" data-request-id="{{item.requestId}}" data-is-pending="true" bindtap="onApprovalTap">
      <view class="card-header">
        <view class="initiator-info">
          <text class="initiator-avatar">{{item.initiator.nickname ? item.initiator.nickname[0] : '?'}}</text>
          <text class="initiator-name">{{item.initiator.nickname}}</text>
        </view>
        <text class="badge-pending">等 TA 确认</text>
      </view>
      <text class="block-title">{{item.title}}</text>
      <text class="block-time">{{item.triggerTime || item.startTime}}</text>
      <view wx:if="{{item.description}}" class="block-desc">{{item.description}}</view>
      <view class="card-actions">
        <button class="btn-approve" bindtap="onApprove" data-request-id="{{item.requestId}}" data-recipient-id="{{item.recipientId}}">好的</button>
        <button class="btn-reject" bindtap="onReject" data-request-id="{{item.requestId}}" data-recipient-id="{{item.recipientId}}">不了</button>
      </view>
    </view>
  </view>

  <!-- Initiated tab -->
  <view wx:if="{{activeTab === 'initiated'}}">
    <state-view wx:if="{{initiatedList.length === 0 && !loading}}" empty="{{true}}" emptyText="暂无发起的邀约" actionText="创建邀约" bind:action="onPlusTap" />

    <view wx:for="{{showSearch ? filteredInitiatedList : initiatedList}}" wx:key="id" class="approval-card" data-request-id="{{item.id}}" data-is-pending="false" bindtap="onApprovalTap">
      <view class="card-header">
        <text class="block-title">{{item.title}}</text>
        <text class="badge-{{item.status}}">{{item.status === 'pending' ? '等待中' : item.status === 'partial' ? '部分回应' : item.status === 'completed' ? '已完成' : '已取消'}}</text>
      </view>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{item.progressPercent}}%"></view>
      </view>
      <text class="progress-text">{{item.approvedCount}}/{{item.recipients.length}} 人好的</text>
    </view>
  </view>

  <view wx:if="{{loading && pendingList.length === 0 && initiatedList.length === 0}}" class="skeleton-wrap">
    <skeleton rowCount="4" />
  </view>

  <view wx:if="{{!loading && error && pendingList.length === 0 && initiatedList.length === 0}}" class="error-hint">{{error}}</view>

</scroll-view>
