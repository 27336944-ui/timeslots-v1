	.page {
  min-height: 100vh;
  background: var(--ts-bg-page);
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: var(--ts-space-sm);
  padding: 12rpx 16rpx;
  background: var(--ts-bg-card);
}

.search-input {
  flex: 1;
  height: 88rpx;
  border-radius: var(--ts-radius-3xl);
  background: var(--ts-bg-disabled);
  padding: 0 24rpx;
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
}

.search-cancel {
  font-size: var(--ts-font-callout);
  color: var(--ts-primary);
  padding: 20rpx 12rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
}

.sub-tabs {
  display: flex;
  background: var(--ts-bg-card);
  border-bottom: 1rpx solid var(--ts-border-light);
  position: sticky;
  top: 0;
  z-index: 10;
}

.sub-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: var(--ts-font-body);
  font-weight: var(--weight-medium);
  color: var(--ts-text-secondary);
  position: relative;
}

.sub-tab:active {
  background: var(--ts-bg-disabled);
}

.sub-tab.active {
  color: var(--ts-primary);
  font-weight: var(--weight-semibold);
}

.sub-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: var(--ts-primary);
  border-radius: 2rpx;
}

/* Backward compat: alias sub-tabs to tabs-row */
.tabs-row {
  display: flex;
  background: var(--ts-bg-card);
  border-bottom: 1rpx solid var(--ts-border-light);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: var(--ts-font-body);
  font-weight: var(--weight-medium);
  color: var(--ts-text-secondary);
  position: relative;
}

.tab:active {
  background: var(--ts-bg-disabled);
}

.tab-active {
  color: var(--ts-primary);
  font-weight: var(--weight-semibold);
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: var(--ts-primary);
  border-radius: 2rpx;
}

.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-text {
  display: block;
  font-size: var(--ts-font-body);
  color: var(--ts-text-tertiary);
  margin-bottom: 12rpx;
}

.empty-hint {
  display: block;
  font-size: var(--ts-font-caption);
  color: var(--ts-text-placeholder);
}

	.approval-card {
  background: var(--ts-bg-card);
  margin: 16rpx 20rpx;
  padding: var(--ts-card-padding);
  border-radius: var(--ts-card-radius);
  box-shadow: var(--ts-card-shadow);
  position: relative;
  overflow: hidden;
}

.approval-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: var(--ts-category-accent-work);
  pointer-events: none;
  z-index: 1;
}

.approval-card.cat-work::before { background: var(--ts-category-accent-work); }
.approval-card.cat-life::before { background: var(--ts-category-accent-life); }
.approval-card.cat-private::before { background: var(--ts-category-accent-private); }

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.initiator-info {
  display: flex;
  align-items: center;
  gap: var(--ts-space-sm);
}

.initiator-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--ts-primary);
  color: var(--ts-bg-card);
  font-size: var(--ts-font-small);
  text-align: center;
  line-height: 48rpx;
}

.initiator-name {
  font-size: var(--ts-font-callout);
  color: var(--ts-text-secondary);
}

.badge-pending {
  font-size: var(--ts-font-small);
  color: var(--ts-accent-amber);
  background: var(--ts-badge-yellow-bg);
  padding: 4rpx 16rpx;
  border-radius: var(--ts-radius-sm);
}

.badge-pending, .badge-partial, .badge-completed, .badge-cancelled {
  font-size: var(--ts-font-small);
  padding: 4rpx 16rpx;
  border-radius: var(--ts-radius-sm);
}

.badge-pending {
  color: var(--ts-accent-amber);
  background: var(--ts-badge-yellow-bg);
}

.badge-partial {
  color: var(--ts-primary);
  background: var(--ts-badge-blue-bg);
}

.badge-completed {
  color: var(--ts-status-done);
  background: var(--ts-status-done-bg);
}

.badge-cancelled {
  color: var(--ts-text-tertiary);
  background: var(--ts-bg-disabled);
}

.block-title {
  display: block;
  font-size: var(--ts-font-body);
  font-weight: var(--weight-medium);
  letter-spacing: var(--ts-ls-card-title);
  color: var(--ts-text-primary);
  margin-bottom: 8rpx;
}

.block-time {
  display: block;
  font-size: var(--ts-font-small);
  color: var(--ts-text-tertiary);
}

.block-desc {
  display: block;
  font-size: var(--ts-font-callout);
  color: var(--ts-text-secondary);
  margin-top: 8rpx;
}

.card-actions {
  display: flex;
  gap: var(--ts-space-md);
  margin-top: 16rpx;
}

	.btn-approve, .btn-reject {
  flex: 1;
  font-size: var(--ts-font-callout);
  font-weight: var(--ts-weight-medium);
  padding: 24rpx 0;
  min-height: var(--ts-btn-height);
  text-align: center;
  border-radius: var(--ts-btn-radius);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-approve {
  background: var(--ts-status-done);
  color: var(--ts-bg-card);
}

.btn-approve:active {
  opacity: 0.8;
}

.btn-reject {
  background: var(--ts-bg-disabled);
  color: var(--ts-text-tertiary);
}

.btn-reject:active {
  opacity: 0.7;
}

.btn-reject::after {
  display: none;
}

.progress-bar {
  height: 8rpx;
  background: var(--ts-bg-disabled);
  border-radius: var(--ts-radius-xs);
  margin: 12rpx 0 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--ts-primary);
  border-radius: var(--ts-radius-xs);
}

.progress-text {
  font-size: var(--ts-font-small);
  color: var(--ts-text-tertiary);
}

.loading-hint {
  text-align: center;
  padding: 40rpx;
  color: var(--ts-text-tertiary);
  font-size: var(--ts-font-body);
}

.error-hint {
  text-align: center;
  padding: 40rpx;
  color: var(--ts-danger);
  font-size: var(--ts-font-body);
}

.circle-entry {
  text-align: center;
  padding: var(--ts-space-lg);
  margin: var(--ts-card-gap-page);
  font-size: var(--ts-font-body);
  color: var(--ts-primary);
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
}

/* Circles section */
.circles-section {
  margin: var(--ts-card-gap-page);
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  overflow: hidden;
}

.section-header {
  padding: var(--ts-card-gap-page);
  border-bottom: 1rpx solid var(--ts-border-light);
}

.section-title {
  font-size: var(--ts-font-callout);
  font-weight: var(--weight-semibold);
  color: var(--ts-text-primary);
}

.circle-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--ts-card-gap-page);
  border-bottom: 1rpx solid var(--ts-border-light);
}

.circle-card:last-child {
  border-bottom: none;
}

.circle-info {
  flex: 1;
  min-width: 0;
}

.circle-name {
  display: block;
  font-size: var(--ts-font-body);
  font-weight: var(--weight-medium);
  color: var(--ts-text-primary);
  margin-bottom: 4rpx;
}

.circle-meta {
  display: block;
  font-size: var(--ts-font-small);
  color: var(--ts-text-tertiary);
}

.circle-desc {
  display: block;
  font-size: var(--ts-font-small);
  color: var(--ts-text-placeholder);
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.circle-arrow {
  font-size: var(--ts-font-body);
  color: var(--ts-text-placeholder);
  margin-left: 20rpx;
}

/* Empty circles */
.empty-circles {
  text-align: center;
  padding: 60rpx 40rpx;
  margin: var(--ts-card-gap-page);
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
}

.empty-circles .empty-text {
  font-size: var(--ts-font-body);
  color: var(--ts-text-tertiary);
  margin-bottom: 8rpx;
}

.empty-circles .empty-hint {
  font-size: var(--ts-font-caption);
  color: var(--ts-text-placeholder);
}

/* Dialog */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: var(--ts-overlay-bg);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.dialog-content {
  width: 100%;
  max-width: 600rpx;
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  overflow: hidden;
}

.dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--ts-card-padding);
  border-bottom: 1rpx solid var(--ts-border-light);
}

.dialog-title {
  font-size: var(--ts-font-body);
  font-weight: var(--weight-semibold);
  color: var(--ts-text-primary);
}

.dialog-close {
  font-size: var(--ts-font-body);
  color: var(--ts-text-tertiary);
  padding: var(--ts-card-gap-page);
  min-width: 88rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dialog-tabs {
  display: flex;
  border-bottom: 1rpx solid var(--ts-border-light);
}

.dialog-tab {
  flex: 1;
  text-align: center;
  padding: var(--ts-card-gap-page);
  font-size: var(--ts-font-body);
  color: var(--ts-text-tertiary);
  position: relative;
}

.dialog-tab.active {
  color: var(--ts-primary);
  font-weight: var(--weight-semibold);
}

.dialog-tab.active::after {
  content: '';
  position: absolute;
  bottom: -1rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 4rpx;
  background: var(--ts-primary);
  border-radius: 2rpx;
}

.dialog-form {
  padding: var(--ts-card-padding);
}

.dialog-form .form-item {
  margin-bottom: 24rpx;
}

.dialog-form .form-label {
  font-size: var(--ts-font-caption);
  font-weight: var(--weight-semibold);
  letter-spacing: var(--ts-ls-form-label);
  text-transform: uppercase;
  color: var(--ts-text-tertiary);
  margin-bottom: 10rpx;
}

.dialog-form .form-input,
.dialog-form .form-textarea {
  width: 100%;
  border: 1rpx solid var(--ts-border);
  border-radius: var(--ts-radius-md);
  padding: var(--ts-space-md);
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
  box-sizing: border-box;
}

.dialog-form .form-textarea {
  height: 120rpx;
  resize: none;
}

	.dialog-btn {
  width: 100%;
  height: var(--ts-btn-height);
  border-radius: var(--ts-btn-radius);
  background: var(--ts-primary);
  color: var(--ts-bg-card);
  font-size: var(--ts-font-body);
  font-weight: var(--ts-weight-semibold);
  border: none;
}

.skeleton-wrap {
  padding: var(--ts-space-xl);
}
