<scroll-view class="page" scroll-y refresher-enabled refresher-triggered="{{loading}}" bindrefresherrefresh="onRefresh">
  <privacy-agreement />
  <!-- Circle info -->
  <view class="info-card" wx:if="{{currentCircle}}">
    <view class="info-header">
      <text class="info-name">{{currentCircle.name}}</text>
      <text class="info-role {{'role-' + currentCircle.myRole}}">{{currentCircle.myRole === 'OWNER' ? '圈主' : currentCircle.myRole === 'ADMIN' ? '管理员' : '成员'}}</text>
    </view>
    <text wx:if="{{currentCircle.description}}" class="info-desc">{{currentCircle.description}}</text>
    <view class="info-meta">
      <text class="info-count">{{currentCircle.memberCount}} 人</text>
    </view>
  </view>

  <!-- Invite section -->
  <view class="invite-card" wx:if="{{currentCircle && (currentCircle.myRole === 'OWNER' || currentCircle.myRole === 'ADMIN')}}">
    <view class="invite-header">邀请码</view>
    <view class="invite-code-row">
      <text class="invite-code">{{currentCircle.inviteCode}}</text>
      <button class="btn-copy" bindtap="onCopyCode">复制</button>
      <button class="btn-regenerate" bindtap="onRegenerateCode">刷新</button>
    </view>
  </view>

  <!-- Members -->
  <view class="section" wx:if="{{currentCircle && currentCircle.members}}">
    <view class="section-header">
      <text class="section-title">成员 ({{currentCircle.memberCount}})</text>
    </view>
    <view wx:for="{{currentCircle.members}}" wx:key="id" class="member-item">
      <view class="member-left">
        <view class="member-avatar">{{item.nickname[0]}}</view>
        <view class="member-info">
          <text class="member-name">{{item.nickname}}</text>
          <text class="member-role-tag {{'role-' + item.role}}">{{item.role === 'OWNER' ? '圈主' : item.role === 'ADMIN' ? '管理员' : '成员'}}</text>
        </view>
      </view>
      <view wx:if="{{currentCircle.myRole === 'OWNER' && item.role !== 'OWNER'}}" class="member-remove" data-memberid="{{item.id}}" bindtap="onRemoveMember">移除</view>
      <view wx:if="{{currentCircle.myRole === 'ADMIN' && item.role === 'MEMBER'}}" class="member-remove" data-memberid="{{item.id}}" bindtap="onRemoveMember">移除</view>
    </view>
  </view>

  <!-- Danger zone -->
  <view wx:if="{{currentCircle && currentCircle.myRole === 'OWNER'}}" class="danger-section">
    <button class="btn-danger" bindtap="onDeleteCircle">删除圈子</button>
  </view>
  <view wx:if="{{currentCircle && currentCircle.myRole !== 'OWNER'}}" class="danger-section">
    <button class="btn-danger" bindtap="onLeaveCircle">退出圈子</button>
  </view>

  <view wx:if="{{loading && !currentCircle}}" class="loading-hint">加载中...</view>
  <view wx:if="{{!(loading && !currentCircle) && error && !currentCircle}}" class="error-hint">{{error}}</view>
</scroll-view>
