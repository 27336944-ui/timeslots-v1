.page {
  height: 100vh;
  background: var(--ts-bg-page);
  padding: 0 16px;
  box-sizing: border-box;
}
.info-card {
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: 16px;
  margin: 16px 0;
  box-shadow: var(--ts-card-shadow);
}
.info-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.info-name {
  font-size: 18px;
  font-weight: var(--weight-semibold);
  color: #333;
}
.info-role {
  font-size: 12px;
  padding: 2px 8px;
  border-radius: 10px;
}
.role-OWNER { background: #FFF3E0; color: #E65100; }
.role-ADMIN { background: #E3F2FD; color: #1565C0; }
.role-MEMBER { background: #F5F5F5; color: #666; }
.info-desc {
  font-size: 13px;
  color: #888;
  margin-top: 8px;
  display: block;
}
.info-meta {
  margin-top: 10px;
}
.info-count {
  font-size: 12px;
  color: #999;
}
.invite-card {
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: var(--ts-card-shadow);
}
.invite-header {
  font-size: 14px;
  font-weight: var(--weight-semibold);
  color: #333;
  margin-bottom: 10px;
}
.invite-code-row {
  display: flex;
  align-items: center;
  gap: 8px;
}
.invite-code {
  flex: 1;
  font-size: 18px;
  font-weight: var(--weight-bold);
  color: var(--ts-primary);
  letter-spacing: 2px;
  font-family: monospace;
}
.btn-copy, .btn-regenerate {
  height: 32px;
  line-height: 32px;
  padding: 0 12px;
  font-size: 13px;
  border-radius: 6px;
  border: none;
}
.btn-copy {
  background: var(--ts-primary);
  color: #fff;
}
.btn-regenerate {
  background: var(--ts-bg-disabled);
  color: #666;
}
.section {
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: var(--ts-card-shadow);
}
.section-header {
  margin-bottom: 12px;
}
.section-title {
  font-size: 14px;
  font-weight: var(--weight-semibold);
  color: #333;
}
.member-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
  border-top: 1rpx solid var(--ts-border-light);
}
.member-item:first-child {
  border-top: none;
}
.member-left {
  display: flex;
  align-items: center;
  gap: 10px;
}
.member-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: var(--ts-primary);
  color: #fff;
  text-align: center;
  line-height: 36px;
  font-size: 14px;
}
.member-info {
  display: flex;
  flex-direction: column;
}
.member-name {
  font-size: 14px;
  color: #333;
}
.member-role-tag {
  font-size: 11px;
  padding: 1px 6px;
  border-radius: 8px;
  align-self: flex-start;
  margin-top: 2px;
}
.member-remove {
  color: var(--ts-danger);
  font-size: 13px;
  padding: 6px 10px;
}
.danger-section {
  margin: 20px 0;
}
.btn-danger {
  width: 100%;
  height: 44px;
  line-height: 44px;
  text-align: center;
  background: var(--ts-bg-card);
  color: var(--ts-danger);
  border-radius: var(--ts-radius-md);
  font-size: 15px;
  border: 1rpx solid var(--ts-danger);
  padding: 0;
}
.loading-hint, .error-hint {
  text-align: center;
  padding: 20px;
  font-size: 14px;
  color: #999;
}
.error-hint {
  color: var(--ts-danger);
}
