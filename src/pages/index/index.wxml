
<view class="container">
  <privacy-agreement />
  <view class="card {{connected ? 'success' : 'error'}}">
    <view class="status-row">
      
      <view class="dot {{connected ? 'dot-green' : 'dot-red'}}"></view>
      <text class="status-text">{{connected ? '后端已连接' : '后端未连接'}}</text>
    </view>
    
    <view class="detail-row" wx:if="{{connected}}">
      <text class="label">状态</text>
      <text class="value">{{backendVersion}}</text>
    </view>
    <view class="detail-row" wx:if="{{connected}}">
      <text class="label">数据库</text>
      <text class="value">{{dbStatus}}</text>
    </view>
    
    <view class="detail-row" wx:if="{{!connected}}">
      <text class="label">错误</text>
      <text class="value error-text">{{error}}</text>
    </view>
  </view>
  <view class="footer">timeslots-v1 v0.3</view>

  
  <view class="nav-section">
    <button class="nav-btn" bindtap="goToMine">前往「我的」</button>
  </view>
</view>
