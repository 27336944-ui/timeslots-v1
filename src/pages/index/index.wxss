.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 32rpx;
  background-color: #f5f5f5;
}

.card {
  width: 100%;
  max-width: 600rpx;
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card.success {
  border-left: 6rpx solid #07c160;
}

.card.error {
  border-left: 6rpx solid #ee0a24;
}

.status-row {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.dot-green {
  background-color: #07c160;
}

.dot-red {
  background-color: #ee0a24;
}

.status-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.label {
  font-size: 28rpx;
  color: #999;
}

.value {
  font-size: 28rpx;
  color: #333;
}

.error-text {
  color: #ee0a24;
}

.footer {
  margin-top: 48rpx;
  font-size: 24rpx;
  color: #ccc;
}

.nav-section {
  margin-top: 32rpx;
  width: 100%;
  max-width: 600rpx;
}

.nav-btn {
  width: 100%;
  height: 80rpx;
  border-radius: 12rpx;
  background-color: #4A6CF7;
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
