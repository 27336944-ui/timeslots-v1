.page {
  min-height: 100vh;
  background: var(--ts-bg-page);
}

.search-bar {
  display: flex;
  align-items: center;
  gap: var(--ts-space-md);
  padding: 20rpx 32rpx;
  background: var(--ts-bg-card);
  border-bottom: 1rpx solid var(--ts-border);
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: var(--ts-border-light);
  border-radius: var(--ts-radius-lg);
  padding: 0 24rpx;
  font-size: var(--ts-font-body);
  border: 1rpx solid var(--ts-border);
}

.search-btn {
  font-size: var(--ts-font-body);
  color: var(--ts-primary);
  font-weight: var(--ts-weight-medium);
  padding: var(--ts-space-sm) var(--ts-space-lg);
}

.search-clear {
  font-size: var(--ts-font-title);
  color: var(--ts-text-tertiary);
  padding: var(--ts-space-sm);
}

.empty-hint {
  padding: 160rpx 0;
  text-align: center;
  color: var(--ts-text-tertiary);
  font-size: var(--ts-font-body);
}

.result-group {
  margin: 16rpx 16rpx 0;
  background: var(--ts-bg-card);
  border-radius: var(--ts-radius-lg);
  overflow: hidden;
}

.group-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid var(--ts-border-light);
}

.group-label {
  font-size: var(--ts-font-body);
	font-weight: var(--ts-weight-semibold);
  color: var(--ts-text-primary);
}

.group-count {
  font-size: var(--ts-font-caption);
  color: var(--ts-text-tertiary);
}

.result-item {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--ts-border-light);
}

.result-title {
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
  display: block;
}

.result-subtitle {
  font-size: var(--ts-font-callout);
  color: var(--ts-text-tertiary);
  margin-top: 4rpx;
  display: block;
}
