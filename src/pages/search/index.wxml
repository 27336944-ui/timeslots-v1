<view class="page">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索日程、任务、分组…" value="{{keyword}}" bindinput="onKeywordInput" confirm-type="search" bindconfirm="onSearch" />
    <view class="search-btn" bindtap="onSearch">{{loading ? '…' : '搜索'}}</view>
    <view wx:if="{{searched}}" class="search-clear" bindtap="onClear">✕</view>
  </view>

  <view wx:if="{{!searched && !loading}}" class="empty-hint">
    <text>输入关键词搜索</text>
  </view>

  <state-view wx:if="{{searched && results.length === 0 && !loading}}" empty="{{true}}" emptyText="没有找到相关内容" actionText="返回首页" bind:action="onBackHome" />

  <view wx:for="{{grouped}}" wx:key="type" class="result-group">
    <view class="group-header">
      <text class="group-label">{{group.label}}</text>
      <text class="group-count">{{group.items.length}} 项</text>
    </view>
    <view wx:for="{{group.items}}" wx:key="id" wx:for-item="result" class="result-item" data-index="{{index}}" bindtap="onResultTap">
      <text class="result-title">{{result.title}}</text>
      <text class="result-subtitle" wx:if="{{result.subtitle}}">{{result.subtitle}}</text>
    </view>
  </view>
</view>
