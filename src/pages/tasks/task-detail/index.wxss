.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 32rpx;
}

.form-group {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 72rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 72rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
}

.form-picker-text {
  color: #333;
}

.form-picker-hint {
  color: #bbb;
}

.form-picker-arrow {
  font-size: 24rpx;
  color: #ccc;
}

.form-btn-group {
  display: flex;
  gap: 12rpx;
}

.form-btn {
  flex: 1;
  padding: 12rpx 28rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  border: 2rpx solid #e8e8e8;
  color: #999;
  background: #fff;
  text-align: center;
}

.form-btn-sm {
  flex: 1;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
}

.form-btn.active-work { border-color: #4A6CF7; color: #4A6CF7; background: #f0f4ff; }
.form-btn.active-life { border-color: #52c41a; color: #52c41a; background: #f0fff0; }
.form-btn.active-private { border-color: #faad14; color: #faad14; background: #fffbe6; }
.form-btn.active-high { border-color: #e74c3c; color: #e74c3c; background: #fff0f0; }
.form-btn.active-medium { border-color: #faad14; color: #faad14; background: #fffbe6; }
.form-btn.active-low { border-color: #999; color: #999; background: #f5f5f5; }
.form-btn.active-pending { border-color: #4A6CF7; color: #4A6CF7; background: #f0f4ff; }
.form-btn.active-progress { border-color: #faad14; color: #faad14; background: #fffbe6; }
.form-btn.active-done { border-color: #52c41a; color: #52c41a; background: #f0fff0; }

.step-input-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.step-input {
  flex: 1;
  height: 64rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  color: #333;
}

.step-add-btn {
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  background: #4A6CF7;
  color: #fff;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.step-item:last-child {
  border-bottom: none;
}

.step-checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #fff;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.step-checked {
  background: #52c41a;
  border-color: #52c41a;
}

.step-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.step-text-done {
  text-decoration: line-through;
  color: #bbb;
}

.step-remove {
  font-size: 24rpx;
  color: #ccc;
  padding: 8rpx;
  flex-shrink: 0;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  background: #4A6CF7;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-bottom: 24rpx;
}

.save-btn:active {
  opacity: 0.8;
}

/* View mode */
.view-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.view-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
}

.view-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.view-label {
  font-size: 26rpx;
  color: #999;
  width: 100rpx;
  flex-shrink: 0;
}

.view-text {
  font-size: 28rpx;
  color: #555;
}

.overdue-text {
  color: #e74c3c;
  font-weight: 600;
}

.view-badge {
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.view-badge.badge-work { background: #f0f4ff; color: #4A6CF7; }
.view-badge.badge-life { background: #f0fff0; color: #52c41a; }
.view-badge.badge-private { background: #fffbe6; color: #faad14; }

.section-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.block-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.block-item:last-child {
  border-bottom: none;
}

.block-item-title {
  font-size: 26rpx;
  color: #333;
}

.block-item-time {
  font-size: 22rpx;
  color: #999;
}

.action-row {
  margin-top: 24rpx;
}

.edit-btn, .schedule-btn, .delete-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-bottom: 16rpx;
  border: none;
}

.edit-btn {
  background: #4A6CF7;
  color: #fff;
}

.schedule-btn {
  background: #13c2c2;
  color: #fff;
}

.delete-btn {
  background: #fff;
  color: #e74c3c;
  border: 2rpx solid #e74c3c;
}
