.page {
  min-height: 100vh;
  background: var(--ts-bg-page);
  padding: 28rpx;
}

.form-group {
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: var(--ts-card-padding);
  margin-bottom: var(--ts-card-gap);
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: var(--ts-font-caption);
  font-weight: var(--weight-semibold);
  letter-spacing: var(--ts-ls-form-label);
  text-transform: uppercase;
  color: #999;
  margin-bottom: 10rpx;
}

.form-input {
  width: 100%;
  height: 72rpx;
  border: 1rpx solid var(--ts-border);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: var(--ts-font-body);
  color: #333;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  border: 1rpx solid var(--ts-border);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  font-size: var(--ts-font-body);
  color: #333;
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 72rpx;
  border: 1rpx solid var(--ts-border);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: var(--ts-font-body);
  color: #333;
}

.form-picker-text {
  color: #333;
}

.form-picker-hint {
  color: #bbb;
}

.form-picker-arrow {
  font-size: var(--ts-font-callout);
  color: #ccc;
}

.form-btn-group {
  display: flex;
  gap: var(--ts-space-sm);
}

.form-btn {
  flex: 1;
  padding: 12rpx 28rpx;
  border-radius: var(--ts-radius-md);
  font-size: var(--ts-font-callout);
  border: 1rpx solid var(--ts-border);
  color: #999;
  background: var(--ts-bg-card);
  text-align: center;
}

.form-btn-sm {
  flex: 1;
  padding: 8rpx 20rpx;
  font-size: var(--ts-font-tiny);
}

.form-btn.active-work { border-color: var(--ts-primary); color: var(--ts-primary); background: var(--ts-primary-bg); }
.form-btn.active-life { border-color: var(--ts-status-done); color: var(--ts-status-done); background: #f0fff0; }
.form-btn.active-private { border-color: var(--ts-priority-medium); color: var(--ts-priority-medium); background: #fffbe6; }
.form-btn.active-high { border-color: var(--ts-priority-high); color: var(--ts-priority-high); background: #fff0f0; }
.form-btn.active-medium { border-color: var(--ts-priority-medium); color: var(--ts-priority-medium); background: #fffbe6; }
.form-btn.active-low { border-color: var(--ts-text-tertiary); color: var(--ts-text-tertiary); background: var(--ts-bg-disabled); }
.form-btn.active-pending { border-color: var(--ts-primary); color: var(--ts-primary); background: var(--ts-primary-bg); }
.form-btn.active-progress { border-color: var(--ts-priority-medium); color: var(--ts-priority-medium); background: #fffbe6; }
.form-btn.active-done { border-color: var(--ts-status-done); color: var(--ts-status-done); background: #f0fff0; }

.step-input-row {
  display: flex;
  gap: var(--ts-space-sm);
  margin-bottom: 16rpx;
}

.step-input {
  flex: 1;
  height: 64rpx;
  border: 1rpx solid var(--ts-border);
  border-radius: var(--ts-radius-md);
  padding: 0 16rpx;
  font-size: var(--ts-font-body);
  color: #333;
}

.step-add-btn {
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: var(--ts-radius-md);
  background: var(--ts-primary);
  color: #fff;
  font-size: var(--ts-font-callout);
  font-weight: var(--weight-medium);
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--ts-border-light);
}

.step-item:last-child {
  border-bottom: none;
}

.step-checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 1rpx solid #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #fff;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.step-checked {
  background: var(--ts-status-done);
  border-color: var(--ts-status-done);
}

.step-text {
  flex: 1;
  font-size: var(--ts-font-body);
  color: #333;
}

.step-text-done {
  text-decoration: line-through;
  color: var(--ts-text-placeholder);
}

.step-remove {
  font-size: var(--ts-font-tiny);
  color: #ccc;
  padding: 8rpx;
  flex-shrink: 0;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 20rpx;
  background: var(--ts-primary);
  color: #fff;
  font-size: var(--ts-font-title1);
  font-weight: var(--weight-semibold);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-bottom: var(--ts-card-gap);
}

.save-btn:active {
  opacity: 0.8;
}

/* View mode */
.view-card {
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: var(--ts-card-padding);
  margin-bottom: var(--ts-card-gap);
  box-shadow: var(--ts-card-shadow);
}

.view-title {
  font-size: 40rpx;
  font-weight: var(--weight-bold);
  color: #333;
  margin-bottom: 24rpx;
}

.view-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.view-label {
  font-size: var(--ts-font-caption);
  font-weight: var(--weight-semibold);
  letter-spacing: var(--ts-ls-form-label);
  text-transform: uppercase;
  color: #999;
  width: 100rpx;
  flex-shrink: 0;
}

.view-text {
  font-size: var(--ts-font-body);
  color: #555;
}

.overdue-text {
  color: var(--ts-danger);
  font-weight: var(--weight-semibold);
}

.view-badge {
  padding: 4rpx 14rpx;
  border-radius: var(--ts-radius-sm);
  font-size: var(--ts-font-tiny);
}

.view-badge.badge-work { background: var(--ts-primary-bg); color: var(--ts-primary); }
.view-badge.badge-life { background: #f0fff0; color: var(--ts-status-done); }
.view-badge.badge-private { background: #fffbe6; color: var(--ts-priority-medium); }

.section-card {
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: var(--ts-card-padding);
  margin-bottom: var(--ts-card-gap);
  box-shadow: var(--ts-card-shadow);
}

.section-title {
  font-size: var(--ts-font-title1);
  font-weight: var(--weight-semibold);
  letter-spacing: var(--ts-ls-card-title);
  color: #333;
  margin-bottom: 16rpx;
}

.block-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--ts-border-light);
}

.block-item:last-child {
  border-bottom: none;
}

.block-item-title {
  font-size: var(--ts-font-callout);
  color: #333;
}

.block-item-time {
  font-size: var(--ts-font-tiny);
  color: #999;
}

.action-row {
  margin-top: var(--ts-card-gap);
}

.done-btn, .edit-btn, .schedule-btn, .delete-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--ts-font-title1);
  font-weight: var(--weight-semibold);
  margin-bottom: var(--ts-card-gap);
  border: none;
}

.edit-btn {
  background: var(--ts-primary);
  color: #fff;
}

.schedule-btn {
  background: #13c2c2;
  color: #fff;
}

.done-btn {
  background: var(--ts-status-done);
  color: #fff;
}

.delete-btn {
  background: var(--ts-bg-card);
  color: var(--ts-danger);
  border: 1rpx solid var(--ts-danger);
}
