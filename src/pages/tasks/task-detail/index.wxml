
<view class="page">
  <privacy-agreement />
  <!-- Create / Edit mode -->
  <block wx:if="{{mode === 'create' || mode === 'edit'}}">
    <view class="form-group">
      <view class="form-item">
        <view class="form-label">标题</view>
        <input class="form-input" value="{{formTitle}}" bindinput="onTitleInput" placeholder="任务标题" />
      </view>

      <view class="form-item">
        <view class="form-label">目标</view>
        <textarea class="form-textarea" value="{{formGoal}}" bindinput="onGoalInput" placeholder="任务目标描述" />
      </view>

      <view class="form-item">
        <view class="form-label">截止日期</view>
        <picker mode="date" value="{{dueAt}}" bindchange="onDueAtChange">
          <view class="form-picker">
            <text class="{{dueAt ? 'form-picker-text' : 'form-picker-hint'}}">{{dueAt || '选择截止日期'}}</text>
            <text class="form-picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="form-item">
        <view class="form-label">分类</view>
        <view class="form-btn-group">
          <view class="form-btn {{formCategory === 'work' ? 'active-work' : ''}}" bindtap="onCategoryChange" data-value="work">工作</view>
          <view class="form-btn {{formCategory === 'life' ? 'active-life' : ''}}" bindtap="onCategoryChange" data-value="life">生活</view>
          <view class="form-btn {{formCategory === 'private' ? 'active-private' : ''}}" bindtap="onCategoryChange" data-value="private">私有</view>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label">优先级</view>
        <view class="form-btn-group">
          <view class="form-btn form-btn-sm {{formPriority === 'high' ? 'active-high' : ''}}" bindtap="onPriorityChange" data-value="high">高</view>
          <view class="form-btn form-btn-sm {{formPriority === 'medium' ? 'active-medium' : ''}}" bindtap="onPriorityChange" data-value="medium">中</view>
          <view class="form-btn form-btn-sm {{formPriority === 'low' ? 'active-low' : ''}}" bindtap="onPriorityChange" data-value="low">低</view>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label">状态</view>
        <view class="form-btn-group">
          <view class="form-btn form-btn-sm {{formStatus === 'pending' ? 'active-pending' : ''}}" bindtap="onStatusChange" data-value="pending">待办</view>
          <view class="form-btn form-btn-sm {{formStatus === 'in_progress' ? 'active-progress' : ''}}" bindtap="onStatusChange" data-value="in_progress">进行中</view>
          <view class="form-btn form-btn-sm {{formStatus === 'done' ? 'active-done' : ''}}" bindtap="onStatusChange" data-value="done">已完成</view>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label">步骤清单</view>
        <view class="step-input-row">
          <input class="step-input" value="{{newStepText}}" bindinput="onNewStepInput" placeholder="添加步骤" />
          <view class="step-add-btn" bindtap="onAddStep">添加</view>
        </view>
        <view wx:for="{{formSteps}}" wx:key="idx" class="step-item" data-idx="{{idx}}">
          <view class="step-checkbox {{item.isDone ? 'step-checked' : ''}}" bindtap="onToggleStep" data-idx="{{idx}}">{{item.isDone ? '✓' : ''}}</view>
          <text class="step-text {{item.isDone ? 'step-text-done' : ''}}">{{item.text}}</text>
          <text class="step-remove" bindtap="onRemoveStep" data-idx="{{idx}}">✕</text>
        </view>
      </view>

      <block wx:if="{{formStatus === 'done' || formCompletedNote || formRetrospective || formImprovements}}">
        <view class="form-item">
          <view class="form-label">完成记录</view>
          <textarea class="form-textarea" value="{{formCompletedNote}}" bindinput="onCompletedNoteInput" placeholder="记录完成情况" />
        </view>
        <view class="form-item">
          <view class="form-label">复盘</view>
          <textarea class="form-textarea" value="{{formRetrospective}}" bindinput="onRetrospectiveInput" placeholder="复盘总结" />
        </view>
        <view class="form-item">
          <view class="form-label">改进计划</view>
          <textarea class="form-textarea" value="{{formImprovements}}" bindinput="onImprovementsInput" placeholder="后续改进" />
        </view>
      </block>
    </view>

    <button class="save-btn" bindtap="onSave">{{mode === 'create' ? '创建' : '保存'}}</button>
  </block>

  <!-- View mode -->
  <block wx:if="{{mode === 'view'}}">
    <view class="view-card">
      <view class="view-title">{{viewTitle}}</view>
      <view wx:if="{{viewGoal}}" class="view-row">
        <text class="view-label">目标</text>
        <text class="view-text">{{viewGoal}}</text>
      </view>
      <view class="view-row">
        <text class="view-label">分类</text>
        <text class="view-badge {{'badge-' + viewRawCategory}}">{{viewCategory}}</text>
      </view>
      <view class="view-row">
        <text class="view-label">优先级</text>
        <text>{{viewPriority}}</text>
      </view>
      <view class="view-row">
        <text class="view-label">状态</text>
        <text>{{viewStatus === 'pending' ? '待办' : viewStatus === 'in_progress' ? '进行中' : '已完成'}}</text>
      </view>
      <view wx:if="{{viewDueAt}}" class="view-row">
        <text class="view-label">截止</text>
        <text class="{{viewDueAtOverdue ? 'overdue-text' : ''}}">{{viewDueAt}}</text>
      </view>
      <view class="view-row">
        <text class="view-label">创建于</text>
        <text>{{viewCreatedAt}}</text>
      </view>
    </view>

    <!-- Steps -->
    <view class="section-card" wx:if="{{formSteps.length > 0}}">
      <view class="section-title">步骤清单</view>
      <view wx:for="{{formSteps}}" wx:key="idx" class="step-item" data-idx="{{idx}}">
        <view class="step-checkbox {{item.isDone ? 'step-checked' : ''}}">{{item.isDone ? '✓' : ''}}</view>
        <text class="step-text {{item.isDone ? 'step-text-done' : ''}}">{{item.text}}</text>
      </view>
    </view>

    <!-- Completed note + Retrospective -->
    <view class="section-card" wx:if="{{viewCompletedNote || viewRetrospective || viewImprovements}}">
      <view wx:if="{{viewCompletedNote}}" class="view-row">
        <text class="view-label">完成记录</text>
        <text class="view-text">{{viewCompletedNote}}</text>
      </view>
      <view wx:if="{{viewRetrospective}}" class="view-row">
        <text class="view-label">复盘</text>
        <text class="view-text">{{viewRetrospective}}</text>
      </view>
      <view wx:if="{{viewImprovements}}" class="view-row">
        <text class="view-label">改进</text>
        <text class="view-text">{{viewImprovements}}</text>
      </view>
    </view>

    <!-- Associated schedules -->
    <view class="section-card" wx:if="{{taskBlocks.length > 0}}">
      <view class="section-title">关联日程 ({{taskBlocks.length}})</view>
      <view wx:for="{{taskBlocks}}" wx:key="id" class="block-item" data-id="{{item.id}}" bindtap="onBlockTap">
        <text class="block-item-title">{{item.title}}</text>
        <text class="block-item-time">{{item._timeRange}}</text>
      </view>
    </view>

    <view class="action-row">
      <button wx:if="{{viewStatus !== 'done'}}" class="done-btn" bindtap="onMarkDone">标记完成</button>
      <button class="edit-btn" bindtap="onEditTap">编辑任务</button>
      <button class="schedule-btn" bindtap="onCreateScheduleTap">创建日程</button>
      <button class="delete-btn" bindtap="onDelete">删除任务</button>
    </view>
  </block>
</view>

