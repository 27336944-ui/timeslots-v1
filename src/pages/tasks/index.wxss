.page {
  height: 100vh;
  background: var(--ts-bg-page);
}

.stats-row {
  display: flex;
  gap: var(--ts-space-sm);
  padding: 16rpx 16rpx 0;
}

.stat-card {
  flex: 1;
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: 16rpx 8rpx;
  text-align: center;
  box-shadow: var(--ts-card-shadow);
}

.stat-num {
  display: block;
  font-size: var(--ts-font-large-title);
  font-weight: var(--weight-bold);
  color: var(--ts-primary);
}

.stat-label {
  display: block;
  font-size: var(--ts-font-tiny);
  color: var(--ts-text-tertiary);
  margin-top: 4rpx;
}

.stat-pending .stat-num { color: var(--ts-status-todo); }
.stat-progress .stat-num { color: var(--ts-priority-medium); }
.stat-done .stat-num { color: var(--ts-status-done); }
.stat-today .stat-num { color: var(--ts-primary); }
.stat-week .stat-num { color: var(--ts-primary); }
.stat-overdue .stat-num { color: var(--ts-priority-high); }
.stat-arranged .stat-num { color: #13c2c2; }

.tabs-row {
  display: flex;
  gap: 8rpx;
  padding: 16rpx 16rpx 0;
}

.tab {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--ts-font-callout);
  color: #999;
  background: var(--ts-bg-card);
  border-radius: var(--ts-radius-md);
}

.tab-active {
  background: var(--ts-primary);
  color: #fff;
  font-weight: var(--weight-semibold);
}

.filter-row {
  display: flex;
  gap: 12rpx;
  padding: 12rpx 16rpx 0;
}

.filter-tag {
  padding: 8rpx 24rpx;
  font-size: var(--ts-font-tiny);
  border-radius: 20rpx;
  background: var(--ts-bg-card);
  color: #999;
  border: 1rpx solid var(--ts-border-light);
}

.filter-tag-active {
  background: var(--ts-primary-bg);
  color: var(--ts-primary);
  border-color: var(--ts-primary);
}

.task-list {
  padding: 12rpx 16rpx 160rpx;
}

.task-card {
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: var(--ts-card-padding);
  margin-bottom: var(--ts-card-gap);
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: var(--ts-card-shadow);
  transition: transform 0.2s ease, opacity 0.2s ease, box-shadow 0.2s ease;
  animation: task-card-enter 0.3s ease;
}

@keyframes task-card-enter {
  from { opacity: 0; transform: translateY(-8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.task-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.06);
}

.task-left {
  flex: 1;
  min-width: 0;
}

.task-title {
  font-size: var(--ts-font-body);
  color: #333;
  font-weight: var(--weight-medium);
}

.task-title-done {
  text-decoration: line-through;
  color: var(--ts-text-placeholder);
}

.task-progress-bar {
  height: 6rpx;
  border-radius: 4rpx;
  background: var(--ts-bg-disabled);
  margin-top: 8rpx;
  overflow: hidden;
  width: 80%;
}

.task-progress-fill {
  height: 100%;
  border-radius: 4rpx;
  background: var(--ts-primary);
  transition: width 0.3s ease;
}

.task-due {
  font-size: var(--ts-font-tiny);
  color: #999;
  margin-top: 6rpx;
}

.task-due-overdue {
  color: var(--ts-danger);
}

.task-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.task-badge {
  padding: 4rpx 14rpx;
  border-radius: var(--ts-radius-sm);
  font-size: var(--ts-font-tiny);
}

.badge-work {
  background: var(--ts-category-work-bg);
  color: var(--ts-category-work);
}

.badge-life {
  background: var(--ts-category-life-bg);
  color: var(--ts-category-life);
}

.badge-private {
  background: var(--ts-category-private-bg);
  color: var(--ts-category-private);
}

.task-priority {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.task-priority.priority-high {
  background: var(--ts-priority-high);
}

.task-priority.priority-medium {
  background: var(--ts-priority-medium);
}

.task-priority.priority-low {
  background: var(--ts-priority-low);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  width: 100rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: var(--ts-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  position: relative;
}

.empty-icon::before {
  content: '';
  width: 60rpx;
  height: 80rpx;
  border: 4rpx solid var(--ts-primary);
  border-radius: 4rpx;
  background: #fff;
}

.empty-icon::after {
  content: '✓';
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  font-size: 20rpx;
  color: var(--ts-status-done);
  font-weight: 700;
}

.empty-text {
  font-size: var(--ts-font-body);
  color: var(--ts-text-tertiary);
}

.empty-hint {
  font-size: var(--ts-font-caption);
  color: var(--ts-text-placeholder);
  margin-top: 8rpx;
}

.loading-hint,
.error-hint {
  text-align: center;
  padding: 48rpx;
  font-size: var(--ts-font-body);
  color: #999;
}

.error-hint {
  color: var(--ts-danger);
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 16rpx 0;
}

.top-bar-title {
  font-size: var(--ts-font-large-title);
  font-weight: var(--weight-bold);
  color: #333;
}

.top-bar-actions {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.top-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--ts-font-title1);
}

.top-btn-plus {
  background: var(--ts-primary);
  color: #fff;
  font-weight: var(--weight-light);
  box-shadow: 0 2rpx 8rpx rgba(74, 108, 247, 0.3);
}

.top-btn-plus:active {
  opacity: 0.85;
  transform: scale(0.92);
}

.top-btn-search {
  background: var(--ts-bg-disabled);
  color: #666;
  font-size: var(--ts-font-body);
}

.top-btn-search:active {
  background: var(--ts-border);
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 16rpx;
}

.search-input {
  flex: 1;
  height: 64rpx;
  border-radius: 32rpx;
  background: var(--ts-bg-disabled);
  padding: 0 24rpx;
  font-size: var(--ts-font-body);
  color: #333;
}

.search-cancel {
  font-size: var(--ts-font-callout);
  color: var(--ts-primary);
  padding: 8rpx;
}
