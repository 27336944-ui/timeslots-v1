.page {
  height: 100vh;
  background: var(--ts-bg-page);
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

.delegation-banner {
  background: var(--ts-primary-bg);
  border: 1rpx solid var(--ts-primary);
  margin: 12rpx 16rpx;
  padding: 16rpx 20rpx;
  border-radius: var(--ts-radius-md);
}

.delegation-banner-text {
  font-size: var(--ts-font-callout);
  color: var(--ts-primary);
  font-weight: var(--weight-medium);
}

.stats-row {
  display: flex;
  gap: var(--ts-space-sm);
  padding: 16rpx 16rpx 0;
}

.stat-card {
  flex: 1;
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: 16rpx 8rpx;
  text-align: center;
  box-shadow: var(--ts-card-shadow);
}

.stat-num {
  display: block;
  font-size: var(--ts-font-display);
  font-weight: var(--weight-bold);
  color: var(--ts-primary);
}

.stat-label {
  display: block;
  font-size: var(--ts-font-small);
  color: var(--ts-text-tertiary);
  margin-top: 4rpx;
}

.stat-pending .stat-num { color: var(--ts-status-todo); }
.stat-progress .stat-num { color: var(--ts-priority-medium); }
.stat-done .stat-num { color: var(--ts-status-done); }
.stat-today .stat-num { color: var(--ts-primary); }
.stat-week .stat-num { color: var(--ts-primary); }
.stat-overdue .stat-num { color: var(--ts-priority-high); }
.stat-arranged .stat-num { color: var(--ts-accent-cyan); }

.tabs-row {
  display: flex;
  background: var(--ts-bg-card);
  border-bottom: 1rpx solid var(--ts-border-light);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: var(--ts-font-body);
  font-weight: var(--weight-medium);
  color: var(--ts-text-secondary);
  position: relative;
}

.tab:active {
  background: var(--ts-bg-disabled);
}

.tab-active {
  color: var(--ts-primary);
  font-weight: var(--weight-semibold);
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: var(--ts-primary);
  border-radius: 2rpx;
}

.filter-row {
  display: flex;
  gap: var(--ts-space-sm);
  padding: 12rpx 16rpx 0;
}

.filter-tag {
  padding: 8rpx 24rpx;
  font-size: var(--ts-font-small);
  border-radius: var(--ts-radius-xl);
  background: var(--ts-bg-card);
  color: var(--ts-text-tertiary);
  border: 1rpx solid var(--ts-border-light);
}

.filter-tag-active {
  background: var(--ts-primary-bg);
  color: var(--ts-primary);
  border-color: var(--ts-primary);
}

.task-list {
  padding: 12rpx 16rpx 160rpx;
}

	.task-card {
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: var(--ts-card-padding);
  margin-bottom: var(--ts-card-gap);
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: var(--ts-card-shadow);
  transition: transform 0.2s ease, opacity 0.2s ease, box-shadow 0.2s ease;
  animation: task-card-enter 0.3s ease;
  position: relative;
  overflow: hidden;
}

.task-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: var(--ts-category-accent-work);
  pointer-events: none;
  z-index: 1;
}

.task-card.cat-work::before { background: var(--ts-category-accent-work); }
.task-card.cat-life::before { background: var(--ts-category-accent-life); }
.task-card.cat-private::before { background: var(--ts-category-accent-private); }

@keyframes task-card-enter {
  from { opacity: 0; transform: translateY(-8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.task-card:active {
  transform: scale(0.98);
  box-shadow: var(--ts-shadow-card);
}

.task-left {
  flex: 1;
  min-width: 0;
}

.task-title {
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
  font-weight: var(--weight-medium);
}

.task-title-done {
  text-decoration: line-through;
  color: var(--ts-text-placeholder);
}

.task-progress-bar {
  height: 6rpx;
  border-radius: var(--ts-radius-xs);
  background: var(--ts-bg-disabled);
  margin-top: 8rpx;
  overflow: hidden;
  width: 80%;
}

.task-progress-fill {
  height: 100%;
  border-radius: var(--ts-radius-xs);
  background: var(--ts-primary);
  transition: width 0.3s ease;
}

.task-due {
  font-size: var(--ts-font-small);
  color: var(--ts-text-tertiary);
  margin-top: 6rpx;
}

.task-due-overdue {
  color: var(--ts-danger);
}

.task-right {
  display: flex;
  align-items: center;
  gap: var(--ts-space-sm);
  flex-shrink: 0;
}

.swipe-hint {
  font-size: var(--ts-font-callout);
  color: var(--ts-text-placeholder);
  padding: var(--ts-space-xs);
  opacity: 0.4;
}

.task-badge {
  padding: 4rpx 14rpx;
  border-radius: var(--ts-radius-sm);
  font-size: var(--ts-font-small);
}

.badge-work {
  background: var(--ts-category-work-bg);
  color: var(--ts-category-work);
}

.badge-life {
  background: var(--ts-category-life-bg);
  color: var(--ts-category-life);
}

.badge-private {
  background: var(--ts-category-private-bg);
  color: var(--ts-category-private);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  width: 100rpx;
  height: 120rpx;
  border-radius: var(--ts-radius-lg);
  background: var(--ts-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  position: relative;
}

.empty-icon::before {
  content: '';
  width: 60rpx;
  height: 80rpx;
  border: 4rpx solid var(--ts-primary);
  border-radius: var(--ts-radius-xs);
  background: var(--ts-bg-card);
}

.empty-icon::after {
  content: '\2713';
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  font-size: var(--ts-font-small);
  color: var(--ts-status-done);
  font-weight: var(--weight-bold);
}

.empty-text {
  font-size: var(--ts-font-body);
  color: var(--ts-text-tertiary);
}

.empty-hint {
  font-size: var(--ts-font-caption);
  color: var(--ts-text-placeholder);
  margin-top: 8rpx;
}

.loading-hint,
.error-hint {
  text-align: center;
  padding: 48rpx;
  font-size: var(--ts-font-body);
  color: var(--ts-text-tertiary);
}

.error-hint {
  color: var(--ts-danger);
}

.search-bar {
  display: flex;
  align-items: center;
  gap: var(--ts-space-sm);
  padding: 12rpx 16rpx;
}

.search-input {
  flex: 1;
  height: 88rpx;
  border-radius: var(--ts-radius-3xl);
  background: var(--ts-bg-disabled);
  padding: 0 24rpx;
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
}

.search-cancel {
  font-size: var(--ts-font-callout);
  color: var(--ts-primary);
  padding: 20rpx 12rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
}

.search-cancel:active {
  opacity: 0.7;
}

/* Swipe hint bar */
.swipe-hint-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 12rpx 16rpx;
  padding: 16rpx 20rpx;
  background: var(--ts-primary-bg);
  border: 1rpx solid var(--ts-primary);
  border-radius: var(--ts-radius-md);
  gap: 12rpx;
}

.swipe-hint-arrow {
  font-size: 28rpx;
  color: var(--ts-primary);
}

.swipe-hint-text {
  font-size: 26rpx;
  color: var(--ts-text-secondary);
}

.swipe-hint-close {
  font-size: 24rpx;
  color: var(--ts-text-tertiary);
  padding: 4rpx 8rpx;
}
