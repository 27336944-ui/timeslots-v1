
<scroll-view class="page" scroll-y refresher-enabled refresher-triggered="{{loading}}" bindrefresherrefresh="onRefresh">
  <privacy-agreement />
  <view class="top-bar">
    <view class="top-bar-title">任务</view>
    <view class="top-bar-actions">
      <view class="top-btn top-btn-search" bindtap="onSearchTap">🔍</view>
      <view class="top-btn top-btn-plus" bindtap="onCreateTap">+</view>
    </view>
  </view>
  <view wx:if="{{showSearch}}" class="search-bar">
    <input class="search-input" placeholder="搜索任务标题…" value="{{searchKeyword}}" bindinput="onSearchInput" focus="{{true}}" />
    <view class="search-cancel" bindtap="onSearchClose">取消</view>
  </view>
  <!-- Stats cards row 1 -->
  <view class="stats-row" wx:if="{{stats}}">
    <view class="stat-card">
      <text class="stat-num">{{stats.total}}</text>
      <text class="stat-label">全部</text>
    </view>
    <view class="stat-card stat-pending">
      <text class="stat-num">{{stats.pending}}</text>
      <text class="stat-label">待办</text>
    </view>
    <view class="stat-card stat-progress">
      <text class="stat-num">{{stats.inProgress}}</text>
      <text class="stat-label">进行中</text>
    </view>
    <view class="stat-card stat-done">
      <text class="stat-num">{{stats.done}}</text>
      <text class="stat-label">已完成</text>
    </view>
  </view>

  <!-- Stats cards row 2 -->
  <view class="stats-row" wx:if="{{stats}}">
    <view class="stat-card stat-today">
      <text class="stat-num">{{stats.today}}</text>
      <text class="stat-label">今日</text>
    </view>
    <view class="stat-card stat-week">
      <text class="stat-num">{{stats.week}}</text>
      <text class="stat-label">本周</text>
    </view>
    <view class="stat-card stat-overdue">
      <text class="stat-num">{{stats.overdue}}</text>
      <text class="stat-label">逾期</text>
    </view>
    <view class="stat-card stat-arranged">
      <text class="stat-num">{{stats.arranged}}/{{stats.unarranged}}</text>
      <text class="stat-label">已排/未排</text>
    </view>
  </view>

  <!-- Category tabs -->
  <view class="tabs-row">
    <view wx:for="{{filterList}}" wx:key="key" class="tab {{currentCategory === item.key ? 'tab-active' : ''}}" bindtap="onTabTap" data-category="{{item.key}}">
      {{item.label}}
    </view>
  </view>

  <!-- Task list -->
  <view class="task-list">
    <view wx:if="{{displayTasks.length === 0 && !loading}}" class="empty-state">
      <view class="empty-icon"></view>
      <text class="empty-text">暂无任务</text>
      <text class="empty-hint">点击下方按钮创建新任务</text>
    </view>

    <view wx:for="{{displayTasks}}" wx:key="id" class="task-card" data-id="{{item.id}}" bindtap="onTaskTap" bindtouchstart="onTaskTouchStart" bindtouchmove="onTaskTouchMove" bindtouchend="onTaskTouchEnd" style="transform: translateX({{swipeOffset[item.id] || 0}}rpx); transition: transform 0.2s ease">
      <view class="task-left">
        <view class="task-title {{item._isDone ? 'task-title-done' : ''}}">{{item.title}}</view>
        <view wx:if="{{item._progress > 0 && item._progress < 100}}" class="task-progress-bar">
          <view class="task-progress-fill" style="width: {{item._progress}}%"></view>
        </view>
        <view wx:if="{{item._dueLabel}}" class="task-due {{item._isOverdue ? 'task-due-overdue' : ''}}">{{item._dueLabel}}</view>
      </view>
      <view class="task-right">
        <view wx:if="{{item._isDone}}" class="task-done-badge">✓</view>
        <view class="task-badge {{'badge-' + item.category}}">{{item._categoryLabel}}</view>
        <view class="task-priority {{'priority-' + item.priority}}"></view>
      </view>
    </view>
  </view>

  <view wx:if="{{loading && displayTasks.length === 0}}" class="skeleton-wrap"><skeleton rowCount="5" /></view>
  <view wx:if="{{!(loading && displayTasks.length === 0) && error && displayTasks.length === 0}}" class="error-hint">{{error}}</view>

</scroll-view>
