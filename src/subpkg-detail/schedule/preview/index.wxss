.page {
  min-height: 100vh;
  background: var(--ts-bg-page);
  padding: var(--ts-space-xl);
  padding-bottom: calc(var(--ts-space-xl) + var(--ts-space-xl));
}

.capsule-row {
  display: flex;
  gap: var(--ts-space-sm);
  margin-bottom: var(--ts-space-sm);
}

/* Share sheet modal */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: var(--ts-overlay-bg);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  background: var(--ts-bg-card);
  border-radius: var(--ts-radius-xxl) var(--ts-radius-xxl) 0 0;
  padding: var(--ts-space-xl);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: var(--ts-font-body);
  font-weight: var(--weight-semibold);
  color: var(--ts-text-primary);
}

.modal-close {
  font-size: var(--ts-font-body);
  color: var(--ts-text-tertiary);
  padding: var(--ts-space-xs);
}

.share-options {
  display: flex;
  gap: var(--ts-space-lg);
  justify-content: space-around;
}

.share-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--ts-space-sm);
  padding: var(--ts-space-lg);
  border-radius: var(--ts-radius-lg);
  background: var(--ts-bg-page);
}

.share-option:active {
  opacity: 0.7;
}

.share-option-icon {
  font-size: 48rpx;
}

.share-option-text {
  font-size: var(--ts-font-callout);
  color: var(--ts-text-secondary);
}
