.page {
  min-height: 100vh;
  background: var(--ts-bg-page);
  padding: var(--ts-space-xl);
}

.loading-skeleton {
  padding: var(--ts-card-padding);
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
}

.skeleton-row {
  height: 32rpx;
  border-radius: var(--ts-radius-sm);
  background: var(--ts-bg-disabled);
  margin-bottom: 24rpx;
  animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.skeleton-title {
  width: 40%;
  height: 40rpx;
  margin-bottom: 36rpx;
}

.error-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.error-text {
  font-size: var(--ts-font-body);
  color: var(--ts-text-tertiary);
}

.more-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--ts-space-xs);
  padding: var(--ts-space-md) 0;
  font-size: var(--ts-font-body);
  color: var(--ts-text-tertiary);
}

.more-toggle:active {
  opacity: 0.6;
}

.more-toggle-arrow {
  font-size: var(--ts-font-callout);
  transition: transform 0.2s ease;
}

.more-toggle-arrow-up {
  transform: rotate(90deg);
}

.ts-inset-row-btn-group {
  display: flex;
  flex-wrap: wrap;
  gap: var(--ts-space-xs);
}

.ts-inset-row-btn {
  padding: 8rpx 20rpx;
  border-radius: var(--ts-radius-md);
  font-size: var(--ts-font-small);
  border: 1rpx solid var(--ts-border);
  color: var(--ts-text-tertiary);
  background: var(--ts-bg-card);
}

.ts-inset-row-btn.active {
  border-color: var(--ts-primary);
  color: var(--ts-primary);
  background: var(--ts-primary-bg);
}

.ts-inset-row-clear {
  font-size: var(--ts-font-callout);
  color: var(--ts-danger);
  padding: 4rpx 8rpx;
}

/* Task picker modal */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: var(--ts-overlay-bg);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  background: var(--ts-bg-card);
  border-radius: var(--ts-radius-xxl) var(--ts-radius-xxl) 0 0;
  max-height: 60vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--ts-space-xl);
  border-bottom: 1rpx solid var(--ts-border-light);
}

.modal-title {
  font-size: var(--ts-font-body);
  font-weight: var(--weight-semibold);
  color: var(--ts-text-primary);
}

.modal-close {
  font-size: var(--ts-font-body);
  color: var(--ts-text-tertiary);
  padding: var(--ts-space-xs);
}

.modal-list {
  padding: 16rpx 0;
  max-height: 50vh;
}

.modal-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--ts-border-light);
}

.modal-item:active {
  background: var(--ts-bg-disabled);
}

.modal-item-title {
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.modal-item-status {
  font-size: var(--ts-font-caption);
  color: var(--ts-text-tertiary);
  padding: 4rpx 12rpx;
  background: var(--ts-badge-blue-bg);
  border-radius: var(--ts-radius-sm);
}

.modal-empty {
  text-align: center;
  padding: 48rpx;
  font-size: var(--ts-font-body);
  color: var(--ts-text-tertiary);
}

.view-task-link {
  color: var(--ts-primary);
  text-decoration: underline;
}

/* Approval BottomSheet */
.approval-sheet-body {
  padding: 16rpx 32rpx 48rpx;
}

.approval-sheet-title {
  font-size: var(--ts-font-display);
  font-weight: var(--weight-bold);
  color: var(--ts-text-primary);
  text-align: center;
  margin-bottom: 32rpx;
}

.approval-sheet-section {
  margin-bottom: 20rpx;
}

.approval-sheet-label {
  font-size: var(--ts-font-caption);
  font-weight: var(--weight-semibold);
  letter-spacing: var(--ts-ls-form-label);
  text-transform: uppercase;
  color: var(--ts-text-secondary);
  margin-bottom: 12rpx;
}

.approval-sheet-row {
  display: flex;
  gap: var(--ts-space-md);
}

.approval-sheet-input {
  flex: 1;
  height: 72rpx;
  border: 1rpx solid var(--ts-border);
  border-radius: var(--ts-radius-lg);
  padding: 0 24rpx;
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
  box-sizing: border-box;
}

.approval-sheet-add-btn {
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: var(--ts-radius-md);
  background: var(--ts-primary);
  color: var(--ts-bg-card);
  font-size: var(--ts-font-callout);
  font-weight: var(--weight-medium);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.approval-sheet-add-btn:active {
  opacity: 0.85;
}

.approval-sheet-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--ts-space-sm);
  margin-bottom: 24rpx;
}

.approval-sheet-tag {
  display: flex;
  align-items: center;
  gap: var(--ts-space-xs);
  padding: 8rpx 16rpx;
  border-radius: var(--ts-radius-sm);
  background: var(--ts-primary-bg);
  font-size: var(--ts-font-callout);
  color: var(--ts-primary);
}

.approval-sheet-tag-close {
  font-size: var(--ts-font-small);
  color: var(--ts-text-tertiary);
  padding: 16rpx; /* expand to ≥ 88rpx touch target */
  min-width: 88rpx;
  min-height: 88rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.approval-sheet-actions {
  display: flex;
  gap: var(--ts-space-lg);
  margin-top: 8rpx;
}

.approval-sheet-cancel {
  flex: 1;
  height: var(--ts-btn-height-sm);
  border-radius: var(--ts-btn-radius-sm);
  border: 1rpx solid var(--ts-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--ts-font-body);
  color: var(--ts-text-secondary);
}

.approval-sheet-confirm {
  flex: 2;
  height: var(--ts-btn-height-sm);
  border-radius: var(--ts-btn-radius-sm);
  background: var(--ts-primary);
  color: var(--ts-bg-card);
  font-size: var(--ts-font-body);
  font-weight: var(--ts-weight-semibold);
  display: flex;
  align-items: center;
  justify-content: center;
}

.approval-sheet-confirm:active {
  opacity: 0.85;
}

.approval-sheet-share-btn {
  width: 100%;
  height: var(--ts-btn-height);
  border-radius: var(--ts-btn-radius);
  background: var(--ts-primary);
  color: var(--ts-bg-card);
  border: none;
  font-size: var(--ts-font-body);
  display: flex;
  align-items: center;
  justify-content: center;
}

.approval-sheet-share-btn:active {
  opacity: 0.85;
}

/* Conflict sheet */
.conflict-body {
  padding: 24rpx 32rpx;
}

.conflict-desc {
  font-size: var(--ts-font-body);
  color: var(--ts-text-secondary);
  margin-bottom: 16rpx;
  display: block;
}

.conflict-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--ts-border-light);
}

.conflict-item:last-child {
  border-bottom: none;
}

.conflict-item-title {
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
  font-weight: var(--weight-medium);
}

.conflict-item-time {
  font-size: var(--ts-font-caption);
  color: var(--ts-danger);
}

.conflict-actions {
  display: flex;
  gap: var(--ts-space-md);
  padding: 24rpx 32rpx;
  border-top: 1rpx solid var(--ts-border-light);
}

.conflict-btn {
  flex: 1;
  height: var(--ts-btn-height-sm);
  border-radius: var(--ts-btn-radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--ts-font-body);
  font-weight: var(--ts-weight-semibold);
}

.conflict-btn-back {
  background: var(--ts-bg-card);
  border: 1rpx solid var(--ts-border);
  color: var(--ts-text-secondary);
}

.conflict-btn-force {
  background: var(--ts-danger);
  color: var(--ts-bg-card);
  border: none;
}

/* Recurring edit sheet */
.recurring-body {
  padding: 24rpx 32rpx;
}

.recurring-desc {
  font-size: var(--ts-font-body);
  color: var(--ts-text-secondary);
  margin-bottom: 16rpx;
  display: block;
}

.recurring-option {
  padding: var(--ts-space-lg);
  border: 1rpx solid var(--ts-border);
  border-radius: var(--ts-radius-md);
  margin-bottom: 12rpx;
}

.recurring-option:active {
  background: var(--ts-bg-disabled);
}

.recurring-option-label {
  font-size: var(--ts-font-body);
  font-weight: var(--weight-semibold);
  color: var(--ts-text-primary);
  display: block;
  margin-bottom: 4rpx;
}

.recurring-option-desc {
  font-size: var(--ts-font-caption);
  color: var(--ts-text-tertiary);
}

.approval-sheet-tabs {
  display: flex;
  gap: 0;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--ts-border);
  border-radius: var(--ts-radius-md);
  overflow: hidden;
}

.approval-sheet-tab {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--ts-font-callout);
  color: var(--ts-text-tertiary);
  background: var(--ts-bg-card);
}

.approval-sheet-tab-active {
  background: var(--ts-primary);
  color: var(--ts-bg-card);
  font-weight: var(--weight-medium);
}

.approval-sheet-hint {
  display: block;
  font-size: var(--ts-font-body);
  color: var(--ts-text-secondary);
  line-height: 1.6;
  padding: 8rpx 0;
}

.ts-inset-buffer-row {
  display: flex;
  align-items: center;
  gap: var(--ts-space-xs);
}

.ts-inset-buffer-label {
  font-size: var(--ts-font-caption);
  color: var(--ts-text-tertiary);
}

.ts-inset-buffer-input {
  width: 80rpx;
  height: 56rpx;
  border: 1rpx solid var(--ts-border);
  border-radius: var(--ts-radius-sm);
  text-align: center;
  font-size: var(--ts-font-callout);
  color: var(--ts-text-primary);
}

