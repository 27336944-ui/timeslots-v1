.page {
  min-height: 100vh;
  background: var(--ts-bg-page);
}

.detail-card {
  background: var(--ts-bg-card);
  margin: var(--ts-card-gap-page);
  padding: var(--ts-card-padding);
  border-radius: var(--ts-card-radius);
  box-shadow: var(--ts-card-shadow);
}

.detail-type {
  font-size: var(--ts-font-small);
  color: var(--ts-primary);
  margin-bottom: 8rpx;
}

.detail-title {
  font-size: var(--ts-font-display);
  font-weight: var(--weight-semibold);
  color: var(--ts-text-primary);
  margin-bottom: 16rpx;
}

.detail-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.detail-label {
  font-size: var(--ts-font-caption);
  font-weight: var(--weight-semibold);
  color: var(--ts-text-tertiary);
  width: 80rpx;
  flex-shrink: 0;
}

.detail-value {
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
  flex: 1;
}

.detail-status {
  font-size: var(--ts-font-body);
  font-weight: var(--weight-medium);
}

.detail-status.status-pending { color: var(--ts-accent-amber); }
.detail-status.status-accepted { color: var(--ts-primary); }
.detail-status.status-rejected { color: var(--ts-danger); }
.detail-status.status-completed { color: var(--ts-status-done); }

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: var(--ts-card-gap-page);
  padding: 20rpx 30rpx;
  background: var(--ts-bg-card);
  border-top: 1rpx solid var(--ts-border-light);
}

.btn-accept, .btn-reject {
  flex: 1;
  font-size: var(--ts-font-body);
  font-weight: var(--weight-semibold);
  padding: 24rpx 0;
  text-align: center;
  border-radius: var(--ts-radius-md);
}

.btn-accept {
  background: var(--ts-status-done);
  color: var(--ts-bg-card);
}

.btn-reject {
  background: var(--ts-bg-disabled);
  color: var(--ts-text-tertiary);
}

.deliver-section {
  margin: var(--ts-card-gap-page);
  padding: var(--ts-card-padding);
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  box-shadow: var(--ts-card-shadow);
}

.deliver-input {
  width: 100%;
  min-height: 160rpx;
  border: 1rpx solid var(--ts-border);
  border-radius: var(--ts-radius-lg);
  padding: 16rpx 24rpx;
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.btn-deliver {
  width: 100%;
  height: 88rpx;
  border-radius: var(--ts-radius-xl);
  background: var(--ts-primary);
  color: var(--ts-bg-card);
  font-size: var(--ts-font-body);
  font-weight: var(--weight-semibold);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-deliver:active {
  opacity: 0.8;
}

.skeleton-wrap {
  padding: var(--ts-space-xl);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
}

.empty-icon {
  font-size: var(--ts-font-icon);
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: var(--ts-font-body);
  color: var(--ts-text-tertiary);
}

.form-label {
  font-size: var(--ts-font-caption);
  font-weight: var(--weight-semibold);
  letter-spacing: var(--ts-ls-form-label);
  text-transform: uppercase;
  color: var(--ts-text-tertiary);
  margin-bottom: 10rpx;
}
