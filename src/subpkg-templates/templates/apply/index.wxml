<view class="container">
  <view wx:if="{{loading}}" class="loading-hint">加载模板中...</view>

  <block wx:else>
    <view class="filter-tabs">
      <view
        wx:for="{{filterTypes}}"
        wx:key="value"
        class="tab {{currentFilter === item.value ? 'active' : ''}}"
        data-value="{{item.value}}"
        bindtap="onFilterChange"
      >
        {{item.label}}
      </view>
    </view>

    <view wx:for="{{templates}}" wx:key="id" class="template-card">
      <view class="card-header">
        <text class="card-title">{{item.title}}</text>
        <text wx:if="{{item.isSystem}}" class="system-badge">系统</text>
      </view>
      <text class="card-desc">{{item.name}}</text>
      <view class="card-meta">
        <text wx:if="{{item.estimatedMinutes}}" class="meta-tag">{{item.estimatedMinutes}} 分</text>
        <text wx:if="{{item.defaultDuration}}" class="meta-tag">{{item.defaultDuration}} 分/块</text>
      </view>
      <button class="apply-btn" bindtap="onApply" data-id="{{item.id}}">一键应用</button>
    </view>

    <view wx:if="{{templates.length === 0}}" class="empty-hint">暂无可用模板</view>
  </block>

  <view wx:if="{{showDatePicker}}" class="date-picker-overlay" bindtap="onCancelPicker">
    <view class="date-picker-box" catchtap="">
      <text class="picker-title">选择应用日期</text>
      <picker mode="date" value="{{applyDate}}" bindchange="onApplyDateChange">
        <view class="picker-value">{{applyDate}}</view>
      </picker>
      <view class="picker-actions">
        <view class="picker-btn cancel" bindtap="onCancelPicker">取消</view>
        <view class="picker-btn confirm" bindtap="onConfirmApply">确定</view>
      </view>
    </view>
  </view>
</view>
