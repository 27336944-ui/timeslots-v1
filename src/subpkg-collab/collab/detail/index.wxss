.page {
  min-height: 100vh;
  background: var(--ts-bg-page);
  padding: 0 32rpx;
  box-sizing: border-box;
}
.info-card {
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: var(--ts-space-xl);
  margin: 32rpx 0;
  box-shadow: var(--ts-card-shadow);
}
.info-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.info-name {
  font-size: var(--ts-font-body);
  font-weight: var(--weight-semibold);
  color: var(--ts-text-primary);
}
.info-role {
  font-size: var(--ts-font-callout);
  padding: 4rpx 16rpx;
  border-radius: var(--ts-radius-md);
}
.role-OWNER { background: var(--ts-badge-orange-bg); color: var(--ts-accent-orange); }
.role-ADMIN { background: var(--ts-badge-blue-bg); color: var(--ts-accent-blue); }
.role-MEMBER { background: var(--ts-bg-disabled); color: var(--ts-text-secondary); }
.info-desc {
  font-size: var(--ts-font-body);
  color: var(--ts-text-tertiary);
  margin-top: 16rpx;
  display: block;
}
.info-meta {
  margin-top: 20rpx;
}
.info-count {
  font-size: var(--ts-font-callout);
  color: var(--ts-text-tertiary);
}
.invite-card {
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: var(--ts-space-xl);
  margin-bottom: 24rpx;
  box-shadow: var(--ts-card-shadow);
}
.invite-header {
  font-size: var(--ts-font-body);
  font-weight: var(--weight-semibold);
  color: var(--ts-text-primary);
  margin-bottom: 20rpx;
}
.invite-code-row {
  display: flex;
  align-items: center;
  gap: var(--ts-space-md);
}
.invite-code {
  flex: 1;
  font-size: var(--ts-font-display);
  font-weight: var(--weight-bold);
  color: var(--ts-primary);
  letter-spacing: 4rpx;
  font-family: monospace;
}
.btn-copy, .btn-regenerate {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  font-size: var(--ts-font-body);
  border-radius: var(--ts-radius-sm);
  border: none;
}
.btn-copy {
  background: var(--ts-primary);
  color: var(--ts-bg-card);
}
.btn-regenerate {
  background: var(--ts-bg-disabled);
  color: var(--ts-text-secondary);
}
.section {
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: var(--ts-space-xl);
  margin-bottom: 24rpx;
  box-shadow: var(--ts-card-shadow);
}
.section-header {
  margin-bottom: 24rpx;
}
.section-title {
  font-size: var(--ts-font-body);
  font-weight: var(--weight-semibold);
  color: var(--ts-text-primary);
}
.member-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-top: 1rpx solid var(--ts-border-light);
}
.member-item:first-child {
  border-top: none;
}
.member-left {
  display: flex;
  align-items: center;
  gap: var(--ts-card-gap-page);
}
.member-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--ts-primary);
  color: var(--ts-bg-card);
  text-align: center;
  line-height: 72rpx;
  font-size: var(--ts-font-body);
}
.member-info {
  display: flex;
  flex-direction: column;
}
.member-name {
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
}
.member-role-tag {
  font-size: var(--ts-font-caption);
  padding: 2rpx 12rpx;
  border-radius: var(--ts-radius-sm);
  align-self: flex-start;
  margin-top: 4rpx;
}
.member-remove {
  color: var(--ts-danger);
  font-size: var(--ts-font-body);
  padding: 12rpx 20rpx;
  min-width: 88rpx;
  text-align: center;
}

.member-remove:active {
  opacity: 0.6;
}
.danger-section {
  margin: 40rpx 0;
}
.btn-danger {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: var(--ts-bg-card);
  color: var(--ts-danger);
  border-radius: var(--ts-radius-md);
  font-size: var(--ts-font-body);
  border: 1rpx solid var(--ts-danger);
  padding: 0;
}

.btn-danger:active {
  background: var(--ts-danger);
  color: var(--ts-bg-card);
}

.loading-hint, .error-hint {
  text-align: center;
  padding: 40rpx;
  font-size: var(--ts-font-body);
  color: var(--ts-text-tertiary);
}
.error-hint {
  color: var(--ts-danger);
}