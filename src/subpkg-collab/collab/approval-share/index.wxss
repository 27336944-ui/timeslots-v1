.page {
  min-height: 100vh;
  background: var(--ts-bg-page);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.share-card {
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: 40rpx;
  width: 100%;
  max-width: 600rpx;
  box-shadow: var(--ts-card-shadow);
}

.initiator-info {
  display: flex;
  align-items: center;
  gap: var(--ts-space-sm);
  margin-bottom: 24rpx;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--ts-primary);
  color: var(--ts-bg-card);
  font-size: var(--ts-font-body);
  text-align: center;
  line-height: 64rpx;
}

.initiator-name {
  font-size: var(--ts-font-body);
  color: var(--ts-text-secondary);
}

.block-title {
  font-size: var(--ts-font-display);
  font-weight: var(--weight-semibold);
  color: var(--ts-text-primary);
  margin-bottom: 16rpx;
}

.block-time {
  font-size: var(--ts-font-body);
  color: var(--ts-text-secondary);
  margin-bottom: 8rpx;
}

.block-desc {
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
  margin-top: 16rpx;
  line-height: 1.6;
}

.action-bar {
  display: flex;
  gap: var(--ts-card-gap-page);
  margin-top: 40rpx;
  width: 100%;
  max-width: 600rpx;
}

.btn-approve, .btn-reject {
  flex: 1;
  font-size: var(--ts-font-body);
  font-weight: var(--weight-semibold);
  padding: 24rpx 0;
  text-align: center;
  border-radius: var(--ts-radius-md);
}

.btn-approve {
  background: var(--ts-status-done);
  color: var(--ts-bg-card);
}

.btn-reject {
  background: var(--ts-bg-disabled);
  color: var(--ts-text-tertiary);
}

.login-hint {
  text-align: center;
  margin-top: 40rpx;
  color: var(--ts-text-tertiary);
  font-size: var(--ts-font-body);
}

.login-btn {
  margin-top: 20rpx;
  color: var(--ts-primary);
  font-size: var(--ts-font-body);
  text-align: center;
}

.login-btn:active {
  opacity: 0.7;
}
