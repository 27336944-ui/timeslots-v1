page {
  min-height: 100vh;
  background: var(--ts-bg-page);
}

.approval-card {
  background: var(--ts-bg-card);
  margin: var(--ts-card-gap-page);
  padding: var(--ts-card-padding);
  border-radius: var(--ts-card-radius);
  box-shadow: var(--ts-card-shadow);
}

.section-title {
  font-size: var(--ts-font-body);
  font-weight: var(--weight-medium);
  color: var(--ts-text-primary);
  margin-bottom: 16rpx;
}

.block-title {
  font-size: var(--ts-font-display);
  font-weight: var(--weight-semibold);
  color: var(--ts-text-primary);
  margin-bottom: 12rpx;
}

.block-time {
  font-size: var(--ts-font-callout);
  color: var(--ts-text-secondary);
  margin-bottom: 8rpx;
}

.block-desc {
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
  margin-top: 12rpx;
  line-height: 1.6;
}

.recipient-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--ts-border-light);
}

.recipient-info {
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
}

.recipient-status-approved {
  color: var(--ts-status-done);
  font-size: var(--ts-font-small);
}

.recipient-status-rejected {
  color: var(--ts-danger);
  font-size: var(--ts-font-small);
}

.recipient-status-pending {
  color: var(--ts-accent-amber);
  font-size: var(--ts-font-small);
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: var(--ts-card-gap-page);
  padding: 20rpx 30rpx;
  background: var(--ts-bg-card);
  border-top: 1rpx solid var(--ts-border-light);
}

.btn-approve, .btn-reject {
  flex: 1;
  font-size: var(--ts-font-body);
  font-weight: var(--weight-semibold);
  padding: 24rpx 0;
  text-align: center;
  border-radius: var(--ts-radius-md);
}

.btn-approve {
  background: var(--ts-status-done);
  color: var(--ts-bg-card);
}

.btn-reject {
  background: var(--ts-bg-disabled);
  color: var(--ts-text-tertiary);
}

.btn-resend {
  font-size: var(--ts-font-small);
  color: var(--ts-primary);
  padding: 8rpx 16rpx;
}

.btn-resend:active {
  opacity: 0.7;
}

.skeleton-wrap {
  padding: var(--ts-space-xl);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
}

.empty-icon {
  font-size: var(--ts-font-icon);
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: var(--ts-font-body);
  color: var(--ts-text-tertiary);
}
