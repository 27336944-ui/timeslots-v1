.cp-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 1000;
  transition: background 0.2s ease;
  pointer-events: none;
}
.cp-overlay-show {
  background: var(--ts-overlay-bg);
  pointer-events: auto;
}

.cp-content {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 70vh;
  background: var(--ts-bg-card);
  border-radius: var(--ts-radius-2xl) var(--ts-radius-2xl) 0 0;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
}
.cp-content-show {
  transform: translateY(0);
}

.cp-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--ts-space-lg) var(--ts-space-xl);
  border-bottom: 1rpx solid var(--ts-border-light);
  flex-shrink: 0;
}
.cp-title {
  font-size: var(--ts-font-title);
  font-weight: var(--weight-semibold);
  color: var(--ts-text-primary);
}
.cp-close {
  font-size: var(--ts-font-display);
  color: var(--ts-text-tertiary);
  padding: var(--ts-space-xs);
}

.cp-scroll {
  flex: 1;
  overflow-y: auto;
  padding: var(--ts-space-xs) 0;
}

.cp-loading {
  text-align: center;
  padding: 40rpx 0;
  color: var(--ts-text-tertiary);
  font-size: var(--ts-font-body);
}

.cp-row {
  min-height: 88rpx;
  display: flex;
  align-items: center;
}

.cp-cat {
  flex: 1;
  display: flex;
  align-items: center;
  padding: var(--ts-space-md) var(--ts-space-lg) var(--ts-space-md) 0;
  min-height: 88rpx;
  border-bottom: 1rpx solid var(--ts-border-light);
}
.cp-row:last-child .cp-cat {
  border-bottom: none;
}

.cp-dot {
  width: var(--ts-space-md);
  height: var(--ts-space-md);
  border-radius: 50%;
  margin-right: var(--ts-space-md);
  flex-shrink: 0;
}

.cp-name {
  flex: 1;
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
}

.cp-badge {
  font-size: var(--ts-font-caption);
  color: var(--ts-text-tertiary);
  background: var(--ts-border-light);
  padding: 2rpx var(--ts-space-sm);
  border-radius: var(--ts-radius-sm);
  margin-left: var(--ts-space-xs);
}

.cp-arrow {
  font-size: var(--ts-font-display);
  color: var(--ts-text-tertiary);
  margin-left: var(--ts-space-xs);
  transition: transform 0.2s ease;
}
.cp-arrow.expanded {
  transform: rotate(90deg);
}

.cp-add {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--ts-space-xs);
  padding: var(--ts-space-md) var(--ts-space-lg);
  color: var(--ts-primary);
  min-height: 88rpx;
}
.cp-add-icon {
  font-size: var(--ts-font-title);
  font-weight: var(--weight-bold);
}
.cp-add-text {
  font-size: var(--ts-font-body);
}

.cp-edit-bar {
  display: flex;
  align-items: center;
  gap: var(--ts-space-md);
  padding: var(--ts-space-md) var(--ts-space-lg);
  border-top: 1rpx solid var(--ts-border-light);
  flex-shrink: 0;
  background: var(--ts-bg-card);
}
.cp-edit-input {
  flex: 1;
  height: 64rpx;
  border: 1rpx solid var(--ts-border);
  border-radius: var(--ts-radius-lg);
  padding: 0 var(--ts-space-md);
  font-size: var(--ts-font-body);
}
.cp-edit-actions {
  display: flex;
  gap: var(--ts-space-sm);
}
.cp-edit-btn {
  height: 64rpx;
  padding: 0 var(--ts-space-lg);
  border-radius: var(--ts-radius-lg);
  font-size: var(--ts-font-body);
  display: flex;
  align-items: center;
}
.cp-edit-cancel {
  background: var(--ts-border-light);
  color: var(--ts-text-secondary);
}
.cp-edit-confirm {
  background: var(--ts-primary);
  color: var(--ts-bg-card);
}
