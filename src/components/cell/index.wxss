.cell {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  background: #fff;
  min-height: 96rpx;
}

.cell-bordered {
  border-bottom: 1rpx solid #F0F0F0;
}

.cell:active {
  background: #F8F8F8;
}

.cell-body {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.cell-content {
  flex: 1;
  min-width: 0;
}

.cell-title {
  display: block;
  font-size: 28rpx;
  color: #1A1A1A;
  line-height: 1.4;
}

.cell-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  line-height: 1.3;
}

.cell-arrow {
  font-size: 36rpx;
  color: #CCC;
  margin-left: 8rpx;
}
