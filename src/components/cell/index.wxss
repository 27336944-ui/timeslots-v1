.cell {
  display: flex;
  align-items: center;
  padding: 28rpx var(--ts-space-xl);
  background: var(--ts-bg-card);
  min-height: 96rpx;
}

.cell-bordered {
  border-bottom: 1rpx solid var(--ts-border-light);
}

.cell:active {
  background: var(--ts-bg-disabled);
}

.cell-body {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.cell-content {
  flex: 1;
  min-width: 0;
}

.cell-title {
  display: block;
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
  line-height: 1.4;
}

.cell-desc {
  display: block;
  font-size: var(--ts-font-small);
  color: var(--ts-text-tertiary);
  margin-top: 4rpx;
  line-height: 1.3;
}

.cell-arrow {
  width: 0;
  height: 0;
  border-left: 10rpx solid var(--ts-text-placeholder);
  border-top: 7rpx solid transparent;
  border-bottom: 7rpx solid transparent;
  margin-left: var(--ts-space-xs);
}
