.tag {
  display: inline-flex;
  align-items: center;
  border-radius: 999rpx;
  padding: 4rpx 16rpx;
  font-size: var(--ts-font-tiny);
  line-height: 1.4;
}

.tag-sm { padding: 2rpx 12rpx; font-size: var(--ts-font-tiny); }
.tag-md { padding: 4rpx 16rpx; font-size: var(--ts-font-tiny); }

.tag-default { background: var(--ts-bg-disabled); color: #666; }

.tag-primary { background: var(--ts-primary-bg); color: var(--ts-primary); }

.tag-success { background: #E8F8EE; color: var(--ts-status-done); }

.tag-warning { background: #FFF3E0; color: #FF8C00; }

.tag-danger { background: #FDE8EA; color: var(--ts-danger); }

.tag-text { flex: 1; }

.tag-close {
  margin-left: 8rpx;
  padding: 2rpx;
  font-size: var(--ts-font-body);
  opacity: 0.6;
}
