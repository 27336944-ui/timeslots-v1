.bs-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 1000;
  transition: background 0.3s ease;
  pointer-events: none;
}

.bs-overlay-show {
  background: rgba(0, 0, 0, 0.4);
  pointer-events: auto;
}

.bs-content {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
}

.bs-content-show {
  transform: translateY(0);
}

.bs-handle {
  display: flex;
  justify-content: center;
  padding: 16rpx 0;
}

.bs-handle-bar {
  width: 72rpx;
  height: 8rpx;
  background: #D1D1D6;
  border-radius: 999rpx;
}
