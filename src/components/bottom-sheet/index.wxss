.bs-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 1000;
  transition: background 0.2s ease;
  pointer-events: none;
}

.bs-overlay-show {
  background: var(--ts-overlay-bg);
  pointer-events: auto;
}

.bs-content {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--ts-bg-card);
  border-radius: var(--ts-radius-2xl) var(--ts-radius-2xl) 0 0;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
}

.bs-content-show {
  transform: translateY(0);
}

.bs-handle {
  display: flex;
  justify-content: center;
  padding: var(--ts-space-md) 0;
}

.bs-handle-bar {
  width: 72rpx;
  height: 8rpx;
  background: var(--ts-text-placeholder);
  border-radius: var(--ts-radius-2xl);
}
