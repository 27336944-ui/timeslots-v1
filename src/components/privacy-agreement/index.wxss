.privacy-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--ts-overlay-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.privacy-card {
  width: 580rpx;
  max-height: 80vh;
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.privacy-header {
  font-size: var(--ts-font-display);
  font-weight: var(--weight-semibold);
  color: var(--ts-text-primary);
  text-align: center;
  padding: var(--ts-space-xl) var(--ts-space-xl) var(--ts-space-lg);
}

.privacy-content {
  flex: 1;
  padding: 0 var(--ts-space-xl);
  max-height: 500rpx;
}

.privacy-section {
  display: block;
  font-size: var(--ts-font-body);
  font-weight: var(--weight-semibold);
  color: var(--ts-text-primary);
  margin-top: var(--ts-space-lg);
  margin-bottom: var(--ts-space-xs);
}

.privacy-paragraph {
  display: block;
  font-size: var(--ts-font-callout);
  color: var(--ts-text-secondary);
  line-height: 1.6;
  margin-bottom: var(--ts-space-sm);
}

.privacy-agree-btn {
  margin: var(--ts-space-lg) var(--ts-space-xl) var(--ts-space-xl);
  height: 88rpx;
  border-radius: var(--ts-radius-xl);
  background: var(--ts-primary);
  color: var(--ts-text-on-brand);
  font-size: var(--ts-font-body);
  font-weight: var(--weight-semibold);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.privacy-agree-btn:active {
  opacity: 0.85;
}

.privacy-agree-btn-disabled {
  opacity: 0.6;
}
