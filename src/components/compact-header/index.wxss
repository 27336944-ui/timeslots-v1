/* compact-header 组件局部样式
   统一 sticky 行为：position: sticky; top: 0; z-index: 11
   替代 schedule/tasks/collab 三页复制的 .compact-header CSS */

.compact-header {
  position: sticky;
  top: 0;
  z-index: 11;
  background: var(--ts-bg-card);
  padding: var(--ts-space-md) var(--ts-space-xl) var(--ts-space-xs);
  border-bottom: 1rpx solid var(--ts-border);
}

.ch-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--ts-space-sm);
}

.ch-left {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 0;
}

.ch-date {
  font-size: var(--ts-font-title);
  font-weight: var(--ts-weight-bold);
  color: var(--ts-text-primary);
}

.ch-actions {
  display: flex;
  flex-direction: row;
  gap: var(--ts-space-sm);
}

.ch-actions .top-btn {
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0;
}

/* ── Overview panel slot 容器 ── */
.overview-panel {
  background: var(--ts-bg-panel);
  border-radius: var(--ts-radius-md);
  padding: var(--ts-space-sm) var(--ts-space-lg);
  margin-bottom: var(--ts-space-sm);
}

/* ── 周日历条 ── */
.ch-day-labels {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  margin-bottom: 4rpx;
}

.ch-dl {
  width: 72rpx;
  text-align: center;
  font-size: var(--ts-font-small);
  color: var(--ts-text-tertiary);
}

.ch-day-nums {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
}

.ch-dn {
  width: 72rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 4rpx 0;
}

.ch-dn:active {
  opacity: 0.7;
}

.ch-dn-num {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  border-radius: 50%;
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
}

.ch-dn.today .ch-dn-num {
  background: var(--ts-primary-bg);
  color: var(--ts-primary);
  font-weight: var(--ts-weight-bold);
}

.ch-dn.selected .ch-dn-num {
  background: var(--ts-primary);
  color: var(--ts-bg-card);
  font-weight: var(--ts-weight-bold);
}

.ch-dn-festival {
  font-size: 16rpx;
  color: var(--ts-danger);
  line-height: 1.2;
  margin-top: 2rpx;
  max-width: 72rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

/* ── 圆形操作按钮 ── */
.top-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--ts-font-body);
}

.top-btn-search {
  background: var(--ts-bg-disabled);
  color: var(--ts-text-secondary);
  font-size: var(--ts-font-body);
}

.search-el {
  width: 28rpx;
  height: 28rpx;
  position: relative;
}

.search-el::after {
  content: '';
  position: absolute;
  box-sizing: border-box;
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid var(--ts-text-secondary);
  border-radius: 50%;
  top: 0;
  left: 0;
}

.search-el::before {
  content: '';
  position: absolute;
  box-sizing: border-box;
  width: 12rpx;
  height: 2rpx;
  background: var(--ts-text-secondary);
  border-radius: 1rpx;
  transform: rotate(45deg);
  bottom: 2rpx;
  right: 1rpx;
}

.top-btn-plus {
  background: var(--ts-bg-disabled);
  color: var(--ts-text-secondary);
  font-size: var(--ts-font-body);
}

.top-btn-plus:active {
  background: var(--ts-border);
}

.top-btn-search:active {
  background: var(--ts-border);
}
