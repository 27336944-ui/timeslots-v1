.loading-spinner {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #e0e0e0;
  border-top-color: #07c160;
  border-radius: 50%;
  animation: loading-rotate 0.8s linear infinite;
  margin: auto;
}

@keyframes loading-rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
