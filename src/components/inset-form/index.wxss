.inset {
  background: var(--ts-bg-inset);
  border-radius: var(--ts-radius-card-ios);
  margin: var(--ts-space-lg);
  overflow: hidden;
  box-shadow: var(--ts-shadow-card-ios);
}

.inset-header {
  padding: var(--ts-space-sm) var(--ts-space-lg) var(--ts-space-xs);
  font-size: var(--ts-font-small);
  font-weight: var(--ts-weight-semibold);
  color: var(--ts-text-tertiary);
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.inset-body {
  width: 100%;
}
