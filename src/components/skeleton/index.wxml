
<view class="skeleton">
  
  <view class="skeleton-row" wx:if="{{showAvatar}}">
    
    <view class="skeleton-avatar skeleton-{{avatarShape}}"></view>
    
    <view class="skeleton-lines">
      <view class="skeleton-line w-60"></view>
      <view class="skeleton-line w-40"></view>
    </view>
  </view>
  
  <view class="skeleton-row" wx:for="{{rowCount}}" wx:key="index">
    
    <view class="skeleton-line w-{{index % 3 === 0 ? 90 : index % 3 === 1 ? 75 : 85}}"></view>
  </view>
</view>
