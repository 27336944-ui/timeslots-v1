.skeleton {
  padding: 24rpx 0;
}

.skeleton-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(90deg, #F0F0F0 25%, #E8E8E8 50%, #F0F0F0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.skeleton-circle { border-radius: 50%; }
.skeleton-square { border-radius: 12rpx; }

.skeleton-lines {
  flex: 1;
}

.skeleton-line {
  height: 28rpx;
  background: linear-gradient(90deg, #F0F0F0 25%, #E8E8E8 50%, #F0F0F0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.skeleton-line:last-child { margin-bottom: 0; }

.w-90 { width: 90%; }
.w-85 { width: 85%; }
.w-75 { width: 75%; }
.w-60 { width: 60%; }
.w-40 { width: 40%; }

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
