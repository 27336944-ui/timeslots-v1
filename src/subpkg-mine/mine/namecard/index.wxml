<view class="container">
  <canvas type="2d" id="posterCanvas" class="poster-canvas"></canvas>

  <view class="section">
    <text class="section-title">选择日期</text>
    <picker mode="date" value="{{selectedDate}}" bindchange="onDateChange">
      <view class="date-picker">{{selectedDate}}</view>
    </picker>
  </view>

  <view wx:if="{{loading}}" class="loading-hint">加载中...</view>

  <view wx:else class="stats-grid">
    <view class="stat-card">
      <text class="stat-num">{{totalHours}}</text>
      <text class="stat-label">总时长(小时)</text>
    </view>
    <view class="stat-card">
      <text class="stat-num free">{{freeHours}}</text>
      <text class="stat-label">空闲时长(小时)</text>
    </view>
    <view class="stat-card">
      <text class="stat-num busy">{{busyHours}}</text>
      <text class="stat-label">忙碌时长(小时)</text>
    </view>
    <view class="stat-card">
      <text class="stat-num">{{avgBlockDuration}}</text>
      <text class="stat-label">平均块长(分)</text>
    </view>
  </view>

  <view wx:if="{{!loading && days.length > 0}}" class="weekly-section">
    <text class="section-title">7 日空闲分布</text>
    <view wx:for="{{days}}" wx:key="date" class="day-row">
      <text class="day-label">{{item.dayLabel}}</text>
      <view class="free-bar-bg">
        <view class="free-bar" style="width: {{item.ratio}}%"></view>
      </view>
      <text class="free-label">{{item.freeCount}} 段空闲</text>
    </view>
  </view>

  <button class="generate-btn" bindtap="onGeneratePoster" disabled="{{generating}}">
    {{generating ? '生成中...' : '生成海报'}}
  </button>
  <button class="save-btn" wx:if="{{posterReady}}" bindtap="onSavePoster">保存到相册</button>
</view>
