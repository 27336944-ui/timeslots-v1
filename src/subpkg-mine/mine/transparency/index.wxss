.page {
  min-height: 100vh;
  background: var(--ts-bg-page);
  padding: var(--ts-card-gap-page);
}

.stealth-card {
  display: flex;
  align-items: center;
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: var(--ts-card-padding);
  margin-bottom: 24rpx;
  box-shadow: var(--ts-card-shadow);
}

.stealth-icon {
  font-size: var(--ts-font-hero-title);
  margin-right: 16rpx;
}

.stealth-info {
  flex: 1;
}

.stealth-title {
  font-size: var(--ts-font-body);
  font-weight: var(--weight-semibold);
  color: var(--ts-text-primary);
}

.stealth-desc {
  font-size: var(--ts-font-small);
  color: var(--ts-text-tertiary);
  margin-top: 4rpx;
}

.stealth-switch {
  font-size: var(--ts-font-small);
  font-weight: var(--weight-bold);
  padding: 8rpx 16rpx;
  border-radius: var(--ts-radius-sm);
  background: var(--ts-bg-disabled);
  color: var(--ts-text-tertiary);
}

.stealth-on {
  background: var(--ts-status-done);
  color: var(--ts-bg-card);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.section-title {
  font-size: var(--ts-font-body);
  font-weight: var(--weight-semibold);
  color: var(--ts-text-primary);
}

.section-add {
  font-size: var(--ts-font-body);
  color: var(--ts-primary);
  padding: 8rpx 16rpx;
}

.recipient-card {
  display: flex;
  align-items: center;
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: var(--ts-card-padding);
  margin-bottom: 12rpx;
  box-shadow: var(--ts-card-shadow);
}

.recipient-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--ts-primary);
  color: var(--ts-bg-card);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--ts-font-body);
  font-weight: var(--weight-bold);
  margin-right: 16rpx;
}

.recipient-info {
  flex: 1;
}

.recipient-name {
  font-size: var(--ts-font-body);
  font-weight: var(--weight-medium);
  color: var(--ts-text-primary);
}

.recipient-level {
  font-size: var(--ts-font-small);
  color: var(--ts-text-tertiary);
  margin-top: 4rpx;
}

.recipient-actions {
  display: flex;
  align-items: center;
  gap: var(--ts-space-sm);
}

.recipient-level-btn {
  font-size: var(--ts-font-small);
  color: var(--ts-primary);
  padding: 20rpx 16rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid var(--ts-primary);
  border-radius: var(--ts-radius-sm);
}

.recipient-remove {
  font-size: var(--ts-font-callout);
  color: var(--ts-danger);
  padding: 20rpx 16rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
}

.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--ts-overlay-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.dialog-box {
  width: 80%;
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: var(--ts-card-padding);
}

.dialog-title {
  font-size: var(--ts-font-body);
  font-weight: var(--weight-semibold);
  color: var(--ts-text-primary);
  margin-bottom: 20rpx;
}

.dialog-input {
  width: 100%;
  height: 72rpx;
  border: 1rpx solid var(--ts-border);
  border-radius: var(--ts-radius-lg);
  padding: 0 24rpx;
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.dialog-levels {
  display: flex;
  gap: var(--ts-space-sm);
  margin-bottom: 24rpx;
}

.dialog-level {
  flex: 1;
  padding: var(--ts-space-sm);
  text-align: center;
  border-radius: var(--ts-radius-md);
  border: 1rpx solid var(--ts-border);
  font-size: var(--ts-font-small);
  color: var(--ts-text-tertiary);
}

.dialog-level.active {
  border-color: var(--ts-primary);
  color: var(--ts-primary);
  background: var(--ts-primary-bg);
}

.dialog-actions {
  display: flex;
  gap: var(--ts-space-md);
}

.dialog-cancel, .dialog-confirm {
  flex: 1;
  height: 72rpx;
  border-radius: var(--ts-radius-lg);
  font-size: var(--ts-font-body);
  font-weight: var(--weight-medium);
  border: none;
}

.dialog-cancel {
  background: var(--ts-bg-disabled);
  color: var(--ts-text-tertiary);
}

.dialog-confirm {
  background: var(--ts-primary);
  color: var(--ts-bg-card);
}

.skeleton-wrap {
  padding: var(--ts-space-xl);
}

.empty-state {
  text-align: center;
  padding: 80rpx 32rpx;
}

.empty-text {
  font-size: var(--ts-font-body);
  color: var(--ts-text-tertiary);
}

.empty-hint {
  font-size: var(--ts-font-small);
  color: var(--ts-text-placeholder);
  margin-top: 8rpx;
}
