.page {
  min-height: 100vh;
  background: var(--ts-bg-page);
  padding: 28rpx;
}

.form-group {
  background: var(--ts-bg-card);
  border-radius: var(--ts-card-radius);
  padding: var(--ts-card-padding);
  margin-bottom: var(--ts-card-gap);
}

.form-section-title {
  font-size: var(--ts-font-callout);
  font-weight: var(--weight-semibold);
  color: var(--ts-text-primary);
  display: block;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--ts-border-light);
}

.form-input {
  width: 100%;
  height: 72rpx;
  border: 1rpx solid var(--ts-border);
  border-radius: var(--ts-radius-lg);
  padding: 0 24rpx;
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
  box-sizing: border-box;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: var(--ts-font-caption);
  font-weight: var(--weight-semibold);
  letter-spacing: var(--ts-ls-form-label);
  text-transform: uppercase;
  color: var(--ts-text-tertiary);
  margin-bottom: 10rpx;
}

.form-hint {
  display: block;
  font-size: var(--ts-font-small);
  color: var(--ts-text-placeholder);
  margin-top: 8rpx;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 72rpx;
  border: 1rpx solid var(--ts-border);
  border-radius: var(--ts-radius-lg);
  padding: 0 24rpx;
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
}

.form-picker-text {
  color: var(--ts-text-primary);
}

.form-picker-arrow {
  font-size: var(--ts-font-callout);
  color: var(--ts-text-placeholder);
}

.form-btn-group {
  display: flex;
  gap: var(--ts-space-sm);
}

.form-btn {
  flex: 1;
  padding: 12rpx 28rpx;
  border-radius: var(--ts-radius-md);
  font-size: var(--ts-font-callout);
  border: 1rpx solid var(--ts-border);
  color: var(--ts-text-tertiary);
  background: var(--ts-bg-card);
  text-align: center;
}

.form-btn.active-public {
  border-color: var(--ts-primary);
  color: var(--ts-primary);
  background: var(--ts-primary-bg);
}

.form-btn.active-private {
  border-color: var(--ts-priority-medium);
  color: var(--ts-priority-medium);
  background: var(--ts-bg-card);
}

.form-btn.active-circle {
  border-color: var(--ts-primary);
  color: var(--ts-primary);
  background: var(--ts-primary-bg);
}

.save-btn {
  width: 100%;
  height: 88rpx;
  border-radius: var(--ts-radius-xl);
  background: var(--ts-primary);
  color: var(--ts-bg-card);
  font-size: var(--ts-font-body);
  font-weight: var(--weight-semibold);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.save-btn:active {
  opacity: 0.85;
}

.form-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 72rpx;
}

.form-row-text {
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
}

.form-row-hint {
  font-size: var(--ts-font-caption);
  color: var(--ts-text-placeholder);
}

.form-link {
  border-bottom: 1rpx solid var(--ts-border-light);
}

.form-link:last-child {
  border-bottom: none;
}

.form-link-text {
  font-size: var(--ts-font-body);
  color: var(--ts-text-primary);
}

.form-toggle {
  width: 96rpx;
  height: 52rpx;
  border-radius: 26rpx;
  position: relative;
  cursor: pointer;
  transition: all 0.2s ease;
}

.form-toggle.toggle-on {
  background: var(--ts-primary);
}

.form-toggle.toggle-off {
  background: var(--ts-border);
}

.form-toggle-knob {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--ts-bg-card);
  position: absolute;
  top: 4rpx;
  transition: all 0.2s ease;
}

.toggle-on .form-toggle-knob {
  left: 48rpx;
}

.toggle-off .form-toggle-knob {
  left: 4rpx;
}

