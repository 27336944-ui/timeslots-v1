.page {
  padding: 32rpx;
  padding-bottom: 160rpx;
}

.page__hd {
  margin-bottom: 32rpx;
}

.page__title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.page__desc {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #888;
}

.state {
  padding: 64rpx 32rpx;
  text-align: center;
}

.state__text {
  margin-bottom: 24rpx;
  font-size: 28rpx;
  color: #888;
}

.state--error .state__text {
  color: #e64340;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.fab {
  position: fixed;
  right: 48rpx;
  bottom: 96rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #07c160;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.fab__plus {
  color: #fff;
  font-size: 56rpx;
  line-height: 56rpx;
}
