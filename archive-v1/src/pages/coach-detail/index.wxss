.coach-detail-page {
  min-height: 100vh;
  background: var(--bg-canvas);
  padding-bottom: 80rpx;
}

.cd-header {
  display: flex;
  align-items: center;
  padding: 48rpx 32rpx 24rpx;
  gap: 16rpx;
}

.cd-header__back {
  font-size: 28rpx;
  color: var(--brand-primary);
  padding: 8rpx 0;
}

.cd-header__title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-main);
}

.cd-loading,
.cd-empty {
  text-align: center;
  padding: 120rpx 32rpx;
  color: var(--text-placeholder);
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.cd-empty__sub {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.cd-content {
  padding: 0 32rpx;
}

.cd-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.cd-meta__type {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
}

.cd-meta__date {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.cd-section {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(26, 29, 38, 0.04);
}

.cd-section__title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 20rpx;
}

.cd-score-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.cd-score-card__ring {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--brand-light);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid var(--brand-primary);
}

.cd-score-card__num {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--brand-primary);
}

.cd-score-card__info {
  flex: 1;
}

.cd-score-card__label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-main);
}

.cd-score-card__detail {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.cd-metric-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid var(--bg-canvas);
}

.cd-metric-row:last-child {
  border-bottom: none;
}

.cd-metric-row__label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.cd-metric-row__value {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-main);
}

.cd-metric-row__value--warn {
  color: var(--semantic-warning);
}

.cd-metric-row__value--high {
  color: var(--semantic-danger);
}

.cd-metric-row__value--ok {
  color: var(--semantic-life);
}

.cd-insights {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.cd-insight-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 16rpx;
  background: var(--bg-secondary);
  border-radius: 12rpx;
}

.cd-insight-item__key {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--brand-primary);
}

.cd-insight-item__val {
  font-size: 26rpx;
  color: var(--text-main);
  line-height: 1.5;
}

.cd-insight-empty {
  font-size: 24rpx;
  color: var(--text-placeholder);
  text-align: center;
  padding: 16rpx;
}

.cd-stars {
  display: flex;
  gap: 16rpx;
  justify-content: center;
  margin-bottom: 24rpx;
}

.cd-star {
  font-size: 56rpx;
  color: var(--bg-tertiary);
  transition:
    transform 200ms ease,
    color 200ms ease;
}

.cd-star:active {
  transform: scale(1.2);
}

.cd-star--active {
  color: var(--semantic-warning);
}

.cd-comment-input {
  width: 100%;
  height: 80rpx;
  background: var(--bg-secondary);
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  color: var(--text-main);
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.cd-submit {
  width: 100%;
  height: 88rpx;
  background: var(--brand-primary);
  color: var(--text-inverse);
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cd-submit[disabled] {
  opacity: 0.5;
}

.cd-history {
  margin: 0 32rpx;
}

.cd-history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--bg-canvas);
}

.cd-history-item__type {
  font-size: 26rpx;
  color: var(--text-main);
}

.cd-history-item__date {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.cd-history-item__score {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--brand-primary);
}
