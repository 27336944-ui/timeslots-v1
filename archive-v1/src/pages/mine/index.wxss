.mine-page {
  min-height: 100vh;
  background: var(--bg-canvas);
  padding-bottom: 200rpx;
}
.mine-profile {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx 48rpx;
  background: linear-gradient(180deg, var(--brand-light) 0%, var(--bg-canvas) 100%);
}
.mine-profile__avatar {
  width: 144rpx;
  height: 144rpx;
  background: var(--brand-primary);
  color: var(--text-inverse);
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx var(--brand-glow);
  margin-bottom: 24rpx;
}
.mine-profile__name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-main);
}
.mine-profile__sub {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.mine-quota {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx 32rpx;
}
.mine-quota__card {
  flex: 1;
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(26, 29, 38, 0.04);
}
.mine-quota__label {
  font-size: 24rpx;
  color: var(--text-secondary);
}
.mine-quota__num {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--text-main);
  line-height: 64rpx;
  margin-top: 8rpx;
}
.mine-quota__sub {
  font-size: 22rpx;
  color: var(--text-placeholder);
  margin-top: 4rpx;
}

.mine-section {
  margin: 0 32rpx 32rpx;
}
.mine-section__title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.mine-action {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(26, 29, 38, 0.04);
}
.mine-action__icon {
  width: 64rpx;
  height: 64rpx;
  background: var(--brand-light);
  color: var(--brand-primary);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 24rpx;
}
.mine-action__text {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.mine-action__title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-main);
}
.mine-action__sub {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}
.mine-action__arrow {
  font-size: 24rpx;
  color: var(--text-placeholder);
  font-weight: 300;
}
