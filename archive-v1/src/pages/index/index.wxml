<view class="page">
  <view class="page__hd">
    <view class="page__title">{{title}}</view>
    <view class="page__desc">{{subtitle}}</view>
  </view>

  <view class="card">
    <view class="card__title">后端健康检查</view>
    <view class="card__row">
      <text class="card__label">状态</text>
      <text class="card__value {{statusClass === 'ok' ? 'card__value--ok' : (statusClass === 'error' ? 'card__value--error' : '')}}">
        {{statusText}}
      </text>
    </view>
    <view class="card__row">
      <text class="card__label">时间戳</text>
      <text class="card__value">{{healthTimestamp}}</text>
    </view>
    <view wx:if="{{errorMessage}}" class="card__error">{{errorMessage}}</view>
  </view>

  <button
    class="card"
    style="margin-top: 32rpx; text-align: center; color: var(--primary-color);"
    bindtap="onTapCheckHealth"
    disabled="{{checking}}"
  >
    {{checking ? '检查中…' : '重新检查'}}
  </button>
</view>
