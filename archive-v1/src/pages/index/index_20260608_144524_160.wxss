.page {
  padding: 40rpx 32rpx;
  min-height: 100vh;
  background: var(--bg-canvas);
}

.page__hd {
  margin-bottom: 48rpx;
}

.page__title {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--text-main);
}

.page__desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.card {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.card__title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-main);
  margin-bottom: 24rpx;
}

.card__row {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  line-height: 1.8;
}

.card__label {
  color: var(--text-secondary);
  width: 120rpx;
  flex-shrink: 0;
}

.card__value {
  color: var(--text-main);
  font-family: monospace;
  word-break: break-all;
  flex: 1;
}

.card__value--ok {
  color: var(--brand-primary);
  font-weight: 500;
}

.card__value--error {
  color: var(--semantic-danger);
  font-weight: 500;
}

.card__error {
  font-size: 24rpx;
  color: var(--semantic-danger);
  background: #fdf3f3;
  border-radius: 8rpx;
  padding: 16rpx;
  margin: 16rpx 0;
  word-break: break-all;
}
