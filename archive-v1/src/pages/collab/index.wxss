.collab-page {
  min-height: 100vh;
  background: var(--bg-canvas);
  padding-bottom: 200rpx;
}
.collab-header {
  padding: 48rpx 32rpx 24rpx;
}
.collab-header__title {
  font-size: 44rpx;
  font-weight: 600;
  color: var(--text-main);
}
.collab-header__sub {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.collab-subtabs {
  display: flex;
  padding: 0 32rpx 24rpx;
  gap: 12rpx;
}
.collab-subtabs .ts-tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: var(--bg-secondary);
  color: var(--text-secondary);
  font-size: 28rpx;
  border-radius: 999rpx;
}
.collab-subtabs .ts-tag--active {
  background: var(--brand-light);
  color: var(--brand-primary);
  font-weight: 500;
}

.collab-create {
  margin: 0 32rpx 32rpx;
  padding: 32rpx;
  background: var(--brand-light);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 2rpx dashed var(--brand-primary);
}
.collab-create__text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.collab-create__title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-main);
}
.collab-create__sub {
  font-size: 24rpx;
  color: var(--text-secondary);
}
.collab-create__btn {
  padding: 12rpx 24rpx;
  background: var(--brand-primary);
  color: var(--text-inverse);
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.collab-list {
  padding: 0 32rpx;
}

.collab-card {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(26, 29, 38, 0.04);
  transition: transform 200ms ease;
}
.collab-card:active {
  transform: scale(0.99);
}
.collab-card__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.collab-card__name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
}
.collab-card__role {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: var(--bg-secondary);
  color: var(--text-secondary);
}
.collab-card__role--owner {
  background: #fef3c7;
  color: #b45309;
}
.collab-card__meta {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.collab-empty {
  text-align: center;
  padding: 80rpx 32rpx;
  color: var(--text-placeholder);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.collab-empty__sub {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.collab-card--invite {
  border: 2rpx solid var(--brand-light);
}

.collab-card__tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: var(--bg-secondary);
  color: var(--text-secondary);
}

.collab-card__tag--PUBLIC {
  background: var(--brand-light);
  color: var(--brand-primary);
}

.collab-card__tag--CIRCLE_ONLY {
  background: #fef3c7;
  color: #b45309;
}

.collab-invite-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.collab-invite-btn {
  flex: 1;
  height: 64rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.collab-invite-btn--accept {
  background: var(--brand-primary);
  color: var(--text-inverse);
}

.collab-invite-btn--decline {
  background: var(--bg-secondary);
  color: var(--text-secondary);
}
