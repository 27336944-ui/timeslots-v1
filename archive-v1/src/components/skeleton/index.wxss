/* Skeleton 骨架屏 (AI Loading 用) */
@keyframes tsShimmer {
  0% {
    background-position: -200% 0;
  }
  100% {
    background-position: 200% 0;
  }
}
.ts-skeleton {
  background: linear-gradient(90deg, var(--bg-secondary) 0%, rgba(255, 255, 255, 0.6) 50%, var(--bg-secondary) 100%);
  background-size: 200% 100%;
  animation: tsShimmer 1.6s ease-in-out infinite;
  border-radius: 12rpx;
}
.ts-skeleton--line {
  height: 32rpx;
  margin-bottom: 16rpx;
}
.ts-skeleton--block {
  height: 120rpx;
}
