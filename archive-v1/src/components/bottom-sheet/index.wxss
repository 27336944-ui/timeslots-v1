/* BottomSheet 底部半屏弹窗 */
.ts-bottom-sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--overlay-strong);
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 240ms cubic-bezier(0.32, 0.72, 0, 1);
}
.ts-bottom-sheet-mask--visible {
  opacity: 1;
  pointer-events: auto;
}

.ts-bottom-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-card);
  border-radius: 24rpx 24rpx 0 0;
  box-shadow: 0 -8rpx 32rpx rgba(26, 29, 38, 0.08);
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 320ms cubic-bezier(0.32, 0.72, 0, 1);
  padding-bottom: env(safe-area-inset-bottom);
}
.ts-bottom-sheet--visible {
  transform: translateY(0);
}

.ts-bottom-sheet__handle {
  width: 64rpx;
  height: 8rpx;
  background: var(--bg-tertiary);
  border-radius: 999rpx;
  margin: 16rpx auto 8rpx;
}

.ts-bottom-sheet__header {
  padding: 16rpx 32rpx 24rpx;
}

.ts-bottom-sheet__title {
  font-size: 34rpx;
  line-height: 48rpx;
  font-weight: 600;
  color: var(--text-main);
  text-align: center;
}

.ts-bottom-sheet__body {
  flex: 1;
  overflow-y: auto;
  padding: 0 32rpx 48rpx;
}
